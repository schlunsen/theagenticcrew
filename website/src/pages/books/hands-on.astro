---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
import Nav from '../../components/Nav.astro';
---

<BaseLayout
  title="The Agentic Crew: Hands-On Guide — Learn by Doing"
  description="A free practical exercise book. Set up your machine, fork a real repo, submit a pull request, and build an AI-generated presentation — all from a terminal."
>
  <Nav
    btnLabel="Download Free"
    btnHref="#download"
    btnFrom="#3c8c50"
    btnTo="#286e3c"
    btnFromHover="#4aa064"
    btnShadow="rgba(60, 140, 80, 0.30)"
    isSubpage={true}
  />

  <!-- Hero -->
  <header class="hero">
    <div class="hero-inner">
      <div class="hero-book">
        <div class="book-mock">
          <div class="book-cover">
            <div class="book-spine"></div>
            <div class="book-front">
              <div class="cover-placeholder">
                <span class="cover-eyebrow">LEARN BY DOING</span>
                <span class="cover-title">The Agentic Crew</span>
                <span class="cover-subtitle">Hands-On Guide</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="hero-text">
        <p class="eyebrow">Hands-On Guide</p>
        <h1>Learn by doing, not by reading</h1>
        <p class="tagline">Real tools. Real repositories. Real results.</p>
        <p class="hero-desc">
          Each chapter is an exercise, not an explanation. You'll set up a real development
          environment, submit a pull request to a live repository, build an
          AI-generated multimedia presentation, and pair-program a complete web app with an
          AI agent — all from a terminal, all without prior coding experience.
        </p>
        <div class="hero-stats">
          <div class="stat"><span class="stat-n">4</span><span class="stat-l">exercises</span></div>
          <div class="stat"><span class="stat-n">Real</span><span class="stat-l">repositories</span></div>
          <div class="stat"><span class="stat-n">Free</span><span class="stat-l">forever</span></div>
        </div>
        <div class="hero-actions">
          <a href="#download" class="btn-primary">Download free →</a>
        </div>
      </div>
    </div>
  </header>

  <!-- What's inside -->
  <section class="about">
    <div class="section-inner">
      <div class="about-grid">
        <div class="about-text">
          <p class="section-label">What's inside</p>
          <h2>Four hands-on exercises</h2>
          <p>
            The Hands-On Guide is the practical companion to the main engineering book.
            Where the main book explains the ideas, this one puts them into practice.
          </p>
          <p>
            You don't need to be a programmer. You need to be willing to type commands
            into a terminal and see what happens. That's how you learn this — not by
            reading, but by doing.
          </p>
        </div>
        <div class="about-cards">
          <div class="feature-card">
            <div class="feature-illus"><img src="/illustrations/ho-setup.jpg" alt="" /></div>
            <div class="feature-num">01</div>
            <h3>Setting Up Your Workstation</h3>
            <p>Terminal, package manager, Git, GitHub CLI, and an AI coding assistant — from scratch, on any OS.</p>
          </div>
          <div class="feature-card">
            <div class="feature-illus"><img src="/illustrations/ho-pr.jpg" alt="" /></div>
            <div class="feature-num">02</div>
            <h3>Your First Pull Request</h3>
            <p>Fork a real repository, write a review, commit and push, and submit a pull request that goes live on GitHub.</p>
          </div>
          <div class="feature-card">
            <div class="feature-illus"><img src="/illustrations/ho-aiproject.jpg" alt="" /></div>
            <div class="feature-num">03</div>
            <h3>Your First AI-Generated Project</h3>
            <p>Fork the web-presenter project and use an AI agent with a Hugging Face API key to generate custom illustrations, spoken narration, and animated backgrounds — all from prompts.</p>
          </div>
          <div class="feature-card">
            <div class="feature-illus"><img src="/illustrations/ho-coming.jpg" alt="" /></div>
            <div class="feature-num">04</div>
            <h3>Pair Programming with an Agent</h3>
            <p>Build a complete Travel Bucket List web app from scratch — without writing a single line of code yourself. You describe, the agent builds, you iterate.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Chapters -->
  <section class="chapters">
    <div class="section-inner">
      <p class="section-label">Contents</p>
      <h2>4 exercises — more coming</h2>
      <div class="chapter-grid">
        {[
          ["01", "Setting Up Your Workstation", "Terminal, package manager, Git, GitHub CLI, and an AI coding assistant — from scratch. Each edition is tailored to your OS. Ends with a working environment and a verified connection to GitHub."],
          ["02", "Your First Pull Request", "Fork a real repository, read a chapter, write a review, commit and push, and submit a pull request that goes live on GitHub. The full open-source workflow in one exercise."],
          ["03", "Your First AI-Generated Project", "Fork the web-presenter project and use an AI agent with a Hugging Face API key to generate custom illustrations, spoken narration, and animated backgrounds — all by describing what you want in plain English."],
          ["04", "Pair Programming with an Agent", "Build a complete Travel Bucket List web app from scratch by describing what you want to an AI coding agent. CRUD operations, localStorage persistence, iterative refinement — without writing a single line of code yourself."],
          ["05", "Prompts That Work", "Coming soon — a practical workshop in writing prompts that get consistent, useful results. Anti-patterns, decomposition, and the prompt-as-spec technique."],
          ["06", "Building from Scratch", "Coming soon — start with a blank folder and a one-sentence brief, and build a complete working project using an AI agent from the first line to deployment."],
          ["07", "Adding Guardrails", "Coming soon — take an existing project and add approval gates, permission scoping, and environment-specific rules so the agent can work safely without supervision."],
          ["08", "Multi-Agent Workflows", "Coming soon — run two agents in parallel on separate branches, then review and merge their work. Branch-per-agent isolation in practice."],
          ["09", "CI/CD with Agents", "Coming soon — wire an agent into a GitHub Actions pipeline for automated PR pre-screening and overnight test runs."],
          ["10", "Capstone Project", "Coming soon — a full project from brief to deployed product, using everything covered in the previous exercises."],
        ].map(([num, title, desc]) => (
          <div class={`chapter-row${parseInt(num as string) > 4 ? ' coming' : ''}`}>
            <span class="ch-num">{num}</span>
            <div class="ch-body">
              <strong>{title}</strong>
              <span class="ch-desc">{desc}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Exercise highlights -->
  <section class="exercises">
    <div class="section-inner">
      <p class="section-label">Exercise highlights</p>
      <h2>What you'll actually do</h2>
      <div class="exercise-list">
        <div class="exercise-item">
          <div class="ex-icon">⌨️</div>
          <div class="ex-body">
            <h3>Run real commands</h3>
            <p>Every step uses actual terminal commands — <code>git</code>, <code>gh</code>, <code>python3</code>. No web interfaces, no drag-and-drop.</p>
          </div>
        </div>
        <div class="exercise-item">
          <div class="ex-icon">🌐</div>
          <div class="ex-body">
            <h3>Work with live GitHub repos</h3>
            <p>You'll fork <code>schlunsen/theagenticcrew</code> and <code>schlunsen/web-presenter</code> — real projects with real histories.</p>
          </div>
        </div>
        <div class="exercise-item">
          <div class="ex-icon">🖼️</div>
          <div class="ex-body">
            <h3>Generate AI illustrations</h3>
            <p>Use FLUX.1-schnell via the Hugging Face API to generate ten custom images for your presentation — from plain English descriptions.</p>
          </div>
        </div>
        <div class="exercise-item">
          <div class="ex-icon">🔊</div>
          <div class="ex-body">
            <h3>Generate AI narration</h3>
            <p>Turn your slide text into spoken audio using text-to-speech models on Hugging Face — no recording required.</p>
          </div>
        </div>
        <div class="exercise-item">
          <div class="ex-icon">✨</div>
          <div class="ex-body">
            <h3>Customise animated backgrounds</h3>
            <p>Ask an AI agent to change the Three.js network animation to match your presentation's colour palette — in seconds.</p>
          </div>
        </div>
        <div class="exercise-item">
          <div class="ex-icon">🤝</div>
          <div class="ex-body">
            <h3>Pair-program with an AI agent</h3>
            <p>Build a Travel Bucket List app from scratch — describe what you want, review what the agent builds, iterate until it's right. Full CRUD with localStorage.</p>
          </div>
        </div>
        <div class="exercise-item">
          <div class="ex-icon">📤</div>
          <div class="ex-body">
            <h3>Ship it to GitHub</h3>
            <p>Every exercise ends with a commit and push. Your work lives on GitHub — shareable, versioned, real.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Download -->
  <section class="download" id="download">
    <div class="section-inner download-inner">
      <p class="section-label">Free download</p>
      <h2>Get the guide</h2>
      <p class="dl-sub">Pick your operating system. Available in English and Spanish.</p>

      <div class="lang-tabs">
        <button class="lang-tab active" data-lang="en">🇬🇧 English</button>
        <button class="lang-tab" data-lang="es">🇪🇸 Español</button>
      </div>

      <div class="lang-panel active" data-lang="en">
        <div class="os-grid">
          <a href="/the-agentic-crew-hands-on-windows.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>Windows</h3>
            <p>PowerShell, WinGet, and Windows-specific commands throughout.</p>
          </a>
          <a href="/the-agentic-crew-hands-on-mac.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>macOS</h3>
            <p>Terminal, Homebrew, and macOS-specific commands throughout.</p>
          </a>
          <a href="/the-agentic-crew-hands-on-linux.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>Linux</h3>
            <p>Ubuntu-based examples with apt, adaptable to any distribution.</p>
          </a>
        </div>
      </div>

      <div class="lang-panel" data-lang="es">
        <div class="os-grid">
          <a href="/the-agentic-crew-hands-on-es-windows.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>Windows</h3>
            <p>PowerShell, WinGet y comandos específicos para Windows.</p>
          </a>
          <a href="/the-agentic-crew-hands-on-es-mac.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>macOS</h3>
            <p>Terminal, Homebrew y comandos específicos para macOS.</p>
          </a>
          <a href="/the-agentic-crew-hands-on-es-linux.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>Linux</h3>
            <p>Ejemplos basados en Ubuntu con apt, adaptables a cualquier distribución.</p>
          </a>
        </div>
      </div>

      <p class="dl-note">The lab companion to the engineering and crew books.</p>

      <div class="also-section">
        <p class="also-label">The full series</p>
        <div class="also-links">
          <a href="/books/the-agentic-crew" class="also-link">
            The Agentic Crew — engineering book (18 chapters, 4 languages) →
          </a>
          <a href="/books/crew-guide" class="also-link">
            Crew Member's Guide — for non-coders (2 languages) →
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs  = document.querySelectorAll('.lang-tab');
    const panels = document.querySelectorAll('.lang-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const lang = tab.getAttribute('data-lang');
        tabs.forEach(t  => t.classList.toggle('active', t === tab));
        panels.forEach(p => p.classList.toggle('active', p.getAttribute('data-lang') === lang));
      });
    });
  });
</script>

<style>
  :root {
    --ho-accent: rgb(60, 140, 80);
    --ho-accent-light: rgb(80, 160, 100);
    --ho-accent-deep: rgb(40, 110, 60);
    --ho-glow: rgba(80, 160, 100, 0.12);
  }

  /* ── Hero ── */
  .hero {
    padding: 8rem 2rem 5rem;
    background: linear-gradient(180deg, rgba(80,160,100,0.06) 0%, var(--color-bg) 100%);
  }
  .hero-inner {
    max-width: var(--max-width); margin: 0 auto;
    display: grid; grid-template-columns: auto 1fr; gap: 5rem; align-items: center;
  }
  .book-mock { perspective: 800px; }
  .book-cover {
    width: 220px; height: 312px; position: relative;
    transform: rotateY(-15deg) rotateX(3deg);
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.18));
  }
  .book-cover:hover { transform: rotateY(-5deg) rotateX(1deg) scale(1.03); }
  .book-front {
    width: 100%; height: 100%;
    border-radius: 3px 10px 10px 3px; overflow: hidden;
    box-shadow: 8px 8px 30px rgba(0,0,0,0.15);
    position: relative;
  }
  .cover-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #0a0e1a, #1a2040);
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    padding: 1.5rem; gap: 0.6rem;
  }
  .cover-eyebrow {
    font-size: 0.55rem; font-weight: 700; letter-spacing: 3px;
    color: var(--ho-accent-light); text-align: center;
  }
  .cover-title {
    font-family: var(--font-serif); font-size: 1.4rem; font-weight: 700;
    color: #f0ead6; text-align: center; line-height: 1.2;
  }
  .cover-subtitle {
    font-size: 0.75rem; font-style: italic;
    color: rgba(80,160,100,0.8); text-align: center;
  }
  .book-spine {
    position: absolute; left: -16px; top: 0; width: 16px; height: 100%;
    background: linear-gradient(to right, #2d7a3e, #4a9e5c);
    transform: rotateY(90deg); transform-origin: right;
    border-radius: 3px 0 0 3px;
  }
  .eyebrow {
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ho-accent); margin-bottom: 0.75rem;
  }
  h1 {
    font-family: var(--font-serif); font-size: 3rem; font-weight: 700;
    color: var(--color-text); line-height: 1.15; margin-bottom: 0.75rem;
  }
  .tagline {
    font-family: var(--font-serif); font-size: 1.2rem; font-style: italic;
    color: var(--color-text-muted); margin-bottom: 1.25rem;
  }
  .hero-desc {
    font-size: 1.05rem; color: var(--color-text-muted);
    line-height: 1.75; max-width: 52ch; margin-bottom: 2rem;
  }
  .hero-stats { display: flex; gap: 2.5rem; margin-bottom: 2.5rem; }
  .stat { display: flex; flex-direction: column; gap: 0.15rem; }
  .stat-n { font-size: 2rem; font-weight: 700; color: var(--ho-accent); line-height: 1; }
  .stat-l { font-size: 0.8rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    display: inline-block; padding: 0.85rem 2rem; border-radius: 10px;
    background: linear-gradient(135deg, var(--ho-accent-light), var(--ho-accent-deep));
    color: #fff !important; font-weight: 700; font-size: 1rem;
    box-shadow: 0 4px 20px rgba(80,160,100,0.35);
    transition: transform 0.2s;
  }
  .btn-primary:hover { transform: translateY(-2px); color: #fff !important; }
  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
    .hero-book { display: flex; justify-content: center; }
    h1 { font-size: 2.4rem; }
  }
  @media (max-width: 640px) {
    .hero { padding: 7rem 1.5rem 4rem; }
    .book-cover { width: 160px; height: 228px; }
    h1 { font-size: 2rem; }
  }

  /* ── Shared section styles ── */
  .section-inner { max-width: var(--max-width); margin: 0 auto; padding: 5rem 2rem; }
  .section-label {
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ho-accent); margin-bottom: 0.75rem;
  }
  h2 {
    font-family: var(--font-serif); font-size: 2.2rem; font-weight: 700;
    color: var(--color-text); margin-bottom: 1.5rem;
  }

  /* ── About ── */
  .about { background: var(--color-bg); border-top: 1px solid var(--color-border); }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .about-text p { color: var(--color-text-muted); line-height: 1.8; margin-bottom: 1rem; }
  .about-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .feature-card {
    background: var(--color-bg-card); border: 1px solid rgba(80,160,100,0.2);
    border-radius: 14px; padding: 1.25rem; transition: border-color 0.2s, box-shadow 0.2s;
  }
  .feature-card:hover {
    border-color: var(--ho-accent-light);
    box-shadow: 0 4px 20px rgba(80,160,100,0.1);
  }
  .feature-card.coming { opacity: 0.6; border-style: dashed; }
  .feature-card.coming:hover { opacity: 0.8; }
  .feature-illus {
    width: 100%; height: 120px; margin-bottom: 0.85rem;
    border-radius: 10px; overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }
  .feature-illus img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .feature-num {
    font-family: var(--font-mono); font-size: 0.85rem; font-weight: 700;
    color: var(--ho-accent); margin-bottom: 0.5rem;
  }
  .feature-card h3 { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--color-text); }
  .feature-card p { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.6; }
  @media (max-width: 900px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-cards { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) { .about-cards { grid-template-columns: 1fr; } }

  /* ── Chapters ── */
  .chapters { background: var(--color-bg-elevated); border-top: 1px solid var(--color-border); }
  .chapter-grid { display: flex; flex-direction: column; }
  .chapter-row {
    display: grid; grid-template-columns: 3rem 1fr;
    gap: 1.25rem; padding: 1rem 0;
    border-bottom: 1px solid var(--color-border-light);
    align-items: baseline;
  }
  .chapter-row:last-child { border-bottom: none; }
  .chapter-row.coming { opacity: 0.45; }
  .ch-num { font-family: var(--font-mono); font-size: 0.75rem; color: var(--ho-accent); font-weight: 600; }
  .ch-body { display: flex; flex-direction: column; gap: 0.2rem; }
  .ch-body strong { font-size: 0.95rem; color: var(--color-text); }
  .ch-desc { font-size: 0.85rem; color: var(--color-text-muted); }

  /* ── Exercises ── */
  .exercises { background: var(--color-bg-elevated); border-top: 1px solid var(--color-border); }
  .exercise-list { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .exercise-item {
    display: grid; grid-template-columns: 2.5rem 1fr; gap: 1rem; align-items: start;
    padding: 1.25rem; background: var(--color-bg-card);
    border: 1px solid var(--color-border); border-radius: 14px;
    transition: border-color 0.2s;
  }
  .exercise-item:hover { border-color: var(--ho-accent-light); }
  .ex-icon { font-size: 1.4rem; line-height: 1; padding-top: 0.1rem; }
  .ex-body h3 { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.35rem; color: var(--color-text); }
  .ex-body p { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.6; }
  code {
    font-family: var(--font-mono); font-size: 0.85em;
    background: rgba(80,160,100,0.08); padding: 0.15em 0.4em;
    border-radius: 4px; color: var(--ho-accent-deep);
  }
  @media (max-width: 640px) { .exercise-list { grid-template-columns: 1fr; } }

  /* ── Download ── */
  .download { background: var(--color-bg); border-top: 1px solid var(--color-border); }
  .download-inner { text-align: center; max-width: 640px !important; }
  .dl-sub { color: var(--color-text-muted); margin-bottom: 1.5rem; }

  /* ── Language tabs ── */
  .lang-tabs {
    display: flex; justify-content: center; gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .lang-tab {
    padding: 0.45rem 1.1rem;
    border: 1.5px solid var(--color-border);
    border-radius: 100px;
    background: var(--color-bg-card);
    color: var(--color-text-muted);
    font-size: 0.85rem; font-weight: 600; cursor: pointer;
    font-family: inherit;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .lang-tab:hover { border-color: var(--ho-accent); color: var(--ho-accent); }
  .lang-tab.active {
    border-color: var(--ho-accent);
    background: var(--ho-accent);
    color: #fff;
  }
  .lang-panel { display: none; }
  .lang-panel.active { display: block; }
  .format-card-dim { opacity: 0.5; cursor: default; }
  .format-card-dim:hover { transform: none; box-shadow: none; }
  .os-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
  .format-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
  .format-card {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    background: var(--color-bg-elevated); border: 1px solid rgba(80,160,100,0.2);
    border-radius: 14px; padding: 1.5rem 1rem;
    text-decoration: none; color: inherit;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .format-card:hover {
    border-color: var(--ho-accent-light); transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(80,160,100,0.12); color: inherit;
  }
  .format-icon {
    font-family: var(--font-mono); font-size: 0.8rem; font-weight: 600;
    color: var(--ho-accent-deep); background: rgba(80,160,100,0.1);
    padding: 0.5rem 1rem; border-radius: 8px; letter-spacing: 0.05em;
  }
  .format-card h3 { font-size: 1.1rem; font-weight: 600; color: var(--color-text); }
  .format-card p { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.6; }
  .dl-note { font-size: 0.8rem; color: var(--color-text-muted); opacity: 0.6; margin-top: 0.5rem; }
  .also-section { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .also-label {
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.1em;
