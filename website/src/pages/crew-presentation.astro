---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Agentic Crew — Crew Member's Guide" description="An interactive slide presentation about working with AI agents — for people who don't write code. 9 slides covering the crew book's themes.">

  <div class="presentation" id="presentation">
    <!-- Slide Counter -->
    <div class="slide-counter" id="slide-counter">1 / 9</div>

    <!-- Language Selector -->
    <div class="lang-selector" id="lang-selector">
      <button class="lang-btn active" data-lang="en">EN</button>
      <button class="lang-btn" data-lang="ca">CA</button>
    </div>

    <!-- Audio Controls -->
    <div class="audio-controls" id="audio-controls">
      <button class="audio-toggle" id="audio-toggle" aria-label="Toggle narration audio" title="Toggle narration (A)">
        <svg class="audio-icon audio-on" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
        </svg>
        <svg class="audio-icon audio-off" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="display:none">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
          <line x1="23" y1="9" x2="17" y2="15" />
          <line x1="17" y1="9" x2="23" y2="15" />
        </svg>
      </button>
      <input type="range" class="volume-slider" id="volume-slider" min="0" max="100" value="80" aria-label="Narration volume" title="Volume" />
      <div class="audio-progress" id="audio-progress">
        <div class="audio-progress-bar" id="audio-progress-bar"></div>
      </div>
    </div>

    <!-- Play Overlay -->
    <div class="play-overlay" id="play-overlay">
      <button class="play-overlay-btn" id="play-overlay-btn" aria-label="Start presentation">
        <svg viewBox="0 0 80 80" width="80" height="80" fill="none">
          <circle cx="40" cy="40" r="38" stroke="var(--color-accent)" stroke-width="2" opacity="0.6" />
          <polygon points="32,22 32,58 60,40" fill="var(--color-accent)" opacity="0.9" />
        </svg>
        <span data-i18n="play-overlay-text">Start Presentation</span>
      </button>
    </div>

    <!-- Progress Dots -->
    <div class="progress-dots" id="progress-dots">
      {Array.from({ length: 9 }).map((_, i) => (
        <button class={`dot ${i === 0 ? 'active' : ''}`} data-slide={i} aria-label={`Go to slide ${i + 1}`}></button>
      ))}
    </div>

    <!-- Navigation Arrows -->
    <button class="nav-arrow nav-prev" id="nav-prev" aria-label="Previous slide">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M15 18l-6-6 6-6" />
      </svg>
    </button>
    <button class="nav-arrow nav-next" id="nav-next" aria-label="Next slide">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M9 18l6-6-6-6" />
      </svg>
    </button>

    <!-- ============ SLIDE 1: Title ============ -->
    <section class="slide slide-active" data-index="0">
      <div class="slide-content slide-title-layout">
        <div class="title-icon" aria-hidden="true">
          <svg viewBox="0 0 120 120" width="120" height="120" fill="none" stroke="var(--crew-accent)" stroke-width="1.5">
            <circle cx="60" cy="60" r="50" stroke-dasharray="6 4" opacity="0.25" />
            <circle cx="60" cy="60" r="35" stroke-width="1" opacity="0.15" />
            <!-- People silhouettes -->
            <circle cx="40" cy="45" r="6" opacity="0.4" />
            <path d="M30 65c0-5 4-9 10-9s10 4 10 9" opacity="0.3" />
            <circle cx="60" cy="40" r="7" opacity="0.5" />
            <path d="M49 62c0-6 5-10 11-10s11 4 11 10" opacity="0.4" />
            <circle cx="80" cy="45" r="6" opacity="0.4" />
            <path d="M70 65c0-5 4-9 10-9s10 4 10 9" opacity="0.3" />
            <!-- Connecting dots -->
            <circle cx="60" cy="85" r="3" fill="var(--crew-teal)" opacity="0.4" />
            <line x1="40" y1="65" x2="60" y2="85" stroke="var(--crew-teal)" stroke-width="0.8" opacity="0.2" />
            <line x1="80" y1="65" x2="60" y2="85" stroke="var(--crew-teal)" stroke-width="0.8" opacity="0.2" />
          </svg>
        </div>
        <p class="slide-eyebrow" data-i18n="slide1-eyebrow">A Book by Rasmus Bornhoft Schlunsen</p>
        <h1 class="slide-main-title" data-i18n="slide1-title">The Agentic<br/>Crew</h1>
        <p class="slide-subtitle-big" data-i18n="slide1-subtitle">Crew Member's Guide</p>
        <p class="slide-tagline" data-i18n="slide1-tagline">For people who are great with computers — but don't write code.</p>
        <p class="slide-date" data-i18n="slide1-date">March 2026</p>
      </div>
    </section>

    <!-- ============ SLIDE 2: The Ground Is Shifting ============ -->
    <section class="slide" data-index="1">
      <div class="slide-content slide-image-quote-layout">
        <div class="slide-text-side">
          <h2 class="slide-heading" data-i18n="slide2-heading">The Ground Is Shifting</h2>
          <blockquote class="slide-blockquote" data-i18n="slide2-quote">
            "The line between 'technical' and 'non-technical' is dissolving. Not because everyone is learning to code — but because the tools are learning to listen."
          </blockquote>
        </div>
        <div class="slide-image-side">
          <img src="/illustrations/crew/ch01-welcome.jpg" alt="The ground shifting — a landscape in transformation" class="oval-vignette slide-illustration" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 3: What's Under the Hood ============ -->
    <section class="slide" data-index="2">
      <div class="slide-content slide-center-layout">
        <h2 class="slide-heading" data-i18n="slide3-heading">What's Under the Hood</h2>
        <p class="slide-body slide-body-subtitle" data-i18n="slide3-subtitle">Every app is a restaurant.</p>
        <div class="restaurant-grid">
          <div class="restaurant-card" data-delay="0">
            <div class="restaurant-icon">
              <svg viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="var(--crew-accent)" stroke-width="1.5">
                <rect x="6" y="8" width="36" height="32" rx="4" />
                <line x1="6" y1="16" x2="42" y2="16" />
                <circle cx="12" cy="12" r="1.5" fill="var(--crew-accent)" opacity="0.5" />
                <circle cx="17" cy="12" r="1.5" fill="var(--crew-teal)" opacity="0.5" />
                <circle cx="22" cy="12" r="1.5" fill="var(--crew-accent-light)" opacity="0.5" />
                <rect x="10" y="20" width="14" height="3" rx="1" opacity="0.4" />
                <rect x="10" y="26" width="20" height="3" rx="1" opacity="0.3" />
                <rect x="10" y="32" width="10" height="3" rx="1" opacity="0.2" />
              </svg>
            </div>
            <h3 data-i18n="slide3-frontend">Frontend</h3>
            <p class="restaurant-label" data-i18n="slide3-frontend-meta">The Dining Room</p>
            <p class="restaurant-desc" data-i18n="slide3-frontend-desc">What customers see and touch</p>
          </div>
          <div class="restaurant-card" data-delay="1">
            <div class="restaurant-icon">
              <svg viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="var(--crew-teal)" stroke-width="1.5">
                <rect x="8" y="6" width="32" height="36" rx="3" />
                <path d="M14 18h20M14 24h12M14 30h16" opacity="0.4" />
                <circle cx="36" cy="14" r="5" stroke="var(--crew-accent)" stroke-dasharray="2 2" opacity="0.5" />
                <path d="M34 14l2 2 3-4" stroke="var(--crew-accent)" stroke-width="1.5" opacity="0.5" />
              </svg>
            </div>
            <h3 data-i18n="slide3-backend">Backend</h3>
            <p class="restaurant-label" data-i18n="slide3-backend-meta">The Kitchen</p>
            <p class="restaurant-desc" data-i18n="slide3-backend-desc">Where the real work happens</p>
          </div>
          <div class="restaurant-card" data-delay="2">
            <div class="restaurant-icon">
              <svg viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="var(--crew-accent-deep)" stroke-width="1.5">
                <rect x="8" y="10" width="32" height="28" rx="2" />
                <line x1="8" y1="18" x2="40" y2="18" />
                <line x1="8" y1="26" x2="40" y2="26" />
                <line x1="8" y1="34" x2="40" y2="34" />
                <line x1="22" y1="10" x2="22" y2="38" />
              </svg>
            </div>
            <h3 data-i18n="slide3-database">Database</h3>
            <p class="restaurant-label" data-i18n="slide3-database-meta">The Filing Cabinet</p>
            <p class="restaurant-desc" data-i18n="slide3-database-desc">Where everything is remembered</p>
          </div>
          <div class="restaurant-card" data-delay="3">
            <div class="restaurant-icon">
              <svg viewBox="0 0 48 48" width="48" height="48" fill="none" stroke="var(--crew-accent-light)" stroke-width="1.5">
                <rect x="6" y="8" width="36" height="28" rx="3" />
                <line x1="6" y1="36" x2="42" y2="36" />
                <rect x="14" y="40" width="20" height="3" rx="1" />
                <path d="M14 18l6 4-6 4" opacity="0.5" />
                <line x1="24" y1="26" x2="34" y2="26" opacity="0.3" />
              </svg>
            </div>
            <h3 data-i18n="slide3-cache">Cache</h3>
            <p class="restaurant-label" data-i18n="slide3-cache-meta">The Whiteboard</p>
            <p class="restaurant-desc" data-i18n="slide3-cache-desc">Quick notes for the rush</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 4: What Is an Agent? ============ -->
    <section class="slide" data-index="3">
      <div class="slide-content slide-image-quote-layout">
        <div class="slide-image-side">
          <img src="/illustrations/crew/ch04-agent-loop.jpg" alt="The agent loop — observe, plan, act, check" class="oval-vignette slide-illustration" loading="lazy" />
        </div>
        <div class="slide-text-side">
          <h2 class="slide-heading" data-i18n="slide4-heading">What Is an Agent?</h2>
          <div class="agent-loop-nodes">
            <div class="loop-node" data-delay="0">
              <span class="loop-node-num">1</span>
              <span class="loop-node-label" data-i18n="slide4-observe">Observe</span>
            </div>
            <div class="loop-connector"></div>
            <div class="loop-node" data-delay="1">
              <span class="loop-node-num">2</span>
              <span class="loop-node-label" data-i18n="slide4-plan">Plan</span>
            </div>
            <div class="loop-connector"></div>
            <div class="loop-node" data-delay="2">
              <span class="loop-node-num">3</span>
              <span class="loop-node-label" data-i18n="slide4-act">Act</span>
            </div>
            <div class="loop-connector"></div>
            <div class="loop-node" data-delay="3">
              <span class="loop-node-num">4</span>
              <span class="loop-node-label" data-i18n="slide4-check">Check</span>
            </div>
            <div class="loop-connector loop-connector-return"></div>
            <div class="loop-repeat" data-i18n="slide4-repeat">Repeat</div>
          </div>
          <blockquote class="slide-blockquote slide-blockquote-compact" data-i18n="slide4-quote">
            "Not magic. Not sentient. A loop."
          </blockquote>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 5: Good vs Bad Instructions ============ -->
    <section class="slide" data-index="4">
      <div class="slide-content slide-image-quote-layout slide-image-quote-reverse">
        <div class="slide-image-side">
          <img src="/illustrations/crew/ch05-two-captains.jpg" alt="Two captains — good and bad instructions" class="oval-vignette slide-illustration" loading="lazy" />
        </div>
        <div class="slide-text-side">
          <h2 class="slide-heading" data-i18n="slide5-heading">Good vs Bad Instructions</h2>
          <div class="instruction-split">
            <div class="instruction-card instruction-bad">
              <div class="instruction-label bad-label" data-i18n="slide5-bad-label">BAD</div>
              <p class="instruction-text" data-i18n="slide5-bad-text">"Fix the website"</p>
              <div class="instruction-result">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#ef4444" stroke-width="2">
                  <circle cx="12" cy="12" r="10" />
                  <path d="M8 8l8 8M16 8l-8 8" />
                </svg>
                <span data-i18n="slide5-bad-result">Confused, sprawling changes</span>
              </div>
            </div>
            <div class="instruction-card instruction-good">
              <div class="instruction-label good-label" data-i18n="slide5-good-label">GOOD</div>
              <p class="instruction-text instruction-text-good" data-i18n="slide5-good-text">"Change the homepage button from blue (#3b82f6) to green (#22c55e). Don't change anything else."</p>
              <div class="instruction-result">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#22c55e" stroke-width="2">
                  <circle cx="12" cy="12" r="10" />
                  <path d="M8 12l3 3 5-6" />
                </svg>
                <span data-i18n="slide5-good-result">Precise, verifiable result</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 6: The Trust Gradient ============ -->
    <section class="slide" data-index="5">
      <div class="slide-content slide-image-quote-layout">
        <div class="slide-text-side">
          <h2 class="slide-heading" data-i18n="slide6-heading">The Trust Gradient</h2>
          <div class="trust-gradient-viz">
            <div class="trust-bar">
              <div class="trust-fill" id="trust-fill"></div>
            </div>
            <div class="trust-labels-row">
              <span class="trust-end-label" data-i18n="slide6-tight">Tight control</span>
              <span class="trust-end-label" data-i18n="slide6-full">Full autonomy</span>
            </div>
            <div class="trust-items">
              <div class="trust-item" data-level="1">
                <div class="trust-dot" style="left: 10%"></div>
                <span data-i18n="slide6-item1">Draft internal notes</span>
              </div>
              <div class="trust-item" data-level="2">
                <div class="trust-dot" style="left: 35%"></div>
                <span data-i18n="slide6-item2">Send emails</span>
              </div>
              <div class="trust-item" data-level="3">
                <div class="trust-dot" style="left: 65%"></div>
                <span data-i18n="slide6-item3">Modify database</span>
              </div>
              <div class="trust-item" data-level="4">
                <div class="trust-dot" style="left: 90%"></div>
                <span data-i18n="slide6-item4">Deploy to production</span>
              </div>
            </div>
          </div>
          <blockquote class="slide-blockquote slide-blockquote-compact" data-i18n="slide6-quote">
            "Start tight. Loosen with evidence."
          </blockquote>
        </div>
        <div class="slide-image-side">
          <img src="/illustrations/crew/ch07-trust-gradient.jpg" alt="The trust gradient — from tight control to full autonomy" class="oval-vignette slide-illustration" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 7: Building Something Real ============ -->
    <section class="slide" data-index="6">
      <div class="slide-content slide-image-quote-layout slide-image-quote-reverse">
        <div class="slide-image-side">
          <img src="/illustrations/crew/ch10-building-real.jpg" alt="Building something real — the GlassView story" class="oval-vignette slide-illustration" loading="lazy" />
        </div>
        <div class="slide-text-side">
          <h2 class="slide-heading" data-i18n="slide7-heading">Building Something Real</h2>
          <p class="slide-body" data-i18n="slide7-body">The GlassView story — a window installer's quoting app.</p>
          <div class="capability-list">
            <div class="cap-item" data-delay="0">
              <svg viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="var(--crew-teal)" stroke-width="1.5"><path d="M3 10l5 5L17 5" /></svg>
              <span data-i18n="slide7-cap1">3D window preview</span>
            </div>
            <div class="cap-item" data-delay="1">
              <svg viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="var(--crew-teal)" stroke-width="1.5"><path d="M3 10l5 5L17 5" /></svg>
              <span data-i18n="slide7-cap2">PDF quotes with pricing</span>
            </div>
            <div class="cap-item" data-delay="2">
              <svg viewBox="0 0 20 20" width="18" height="18" fill="none" stroke="var(--crew-teal)" stroke-width="1.5"><path d="M3 10l5 5L17 5" /></svg>
              <span data-i18n="slide7-cap3">Customer database</span>
            </div>
          </div>
          <p class="slide-highlight" data-i18n="slide7-highlight">Built in a weekend. Without writing code.</p>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 8: When Things Go Wrong ============ -->
    <section class="slide" data-index="7">
      <div class="slide-content slide-image-quote-layout">
        <div class="slide-text-side">
          <h2 class="slide-heading" data-i18n="slide8-heading">When Things Go Wrong</h2>
          <div class="war-story-cards">
            <div class="war-story-card" data-delay="0">
              <div class="war-story-icon">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#ef4444" stroke-width="1.5">
                  <rect x="2" y="4" width="20" height="16" rx="2" />
                  <path d="M2 8l10 6 10-6" />
                </svg>
              </div>
              <h3 data-i18n="slide8-story1">The Email That Wasn't Ready</h3>
            </div>
            <div class="war-story-card" data-delay="1">
              <div class="war-story-icon">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#f59e0b" stroke-width="1.5">
                  <path d="M12 2l3 7h7l-5.5 4.5 2 7L12 16l-6.5 4.5 2-7L2 9h7z" />
                </svg>
              </div>
              <h3 data-i18n="slide8-story2">The Confident Statistic</h3>
            </div>
            <div class="war-story-card" data-delay="2">
              <div class="war-story-icon">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#8b5cf6" stroke-width="1.5">
                  <rect x="3" y="3" width="18" height="18" rx="2" />
                  <path d="M8 12h8M12 8v8" />
                </svg>
              </div>
              <h3 data-i18n="slide8-story3">The Overzealous Redesign</h3>
            </div>
          </div>
          <div class="recovery-pattern">
            <span class="recovery-label" data-i18n="slide8-recovery-label">Recovery pattern:</span>
            <div class="recovery-steps">
              <span class="recovery-step" data-i18n="slide8-step1">Stop</span>
              <span class="recovery-arrow">&#8594;</span>
              <span class="recovery-step" data-i18n="slide8-step2">Assess</span>
              <span class="recovery-arrow">&#8594;</span>
              <span class="recovery-step" data-i18n="slide8-step3">Restore</span>
              <span class="recovery-arrow">&#8594;</span>
              <span class="recovery-step" data-i18n="slide8-step4">Learn</span>
              <span class="recovery-arrow">&#8594;</span>
              <span class="recovery-step" data-i18n="slide8-step5">Try again</span>
            </div>
          </div>
        </div>
        <div class="slide-image-side">
          <img src="/illustrations/crew/ch11-when-wrong.jpg" alt="When things go wrong" class="oval-vignette slide-illustration" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 9: Go Build Something ============ -->
    <section class="slide" data-index="8">
      <div class="slide-content slide-title-layout slide-final">
        <h2 class="slide-heading slide-heading-big" data-i18n="slide9-heading">Now go build something.</h2>
        <div class="final-illustration">
          <img src="/illustrations/crew/ch16-final-words.jpg" alt="Go build something" class="oval-vignette slide-illustration slide-illustration-final" loading="lazy" />
        </div>
        <div class="final-actions">
          <a href="/" class="btn-primary-slide">
            <span data-i18n="slide9-cta">Get the Book — Free</span>
            <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 3v10m0 0l-4-4m4 4l4-4M3 17h14" />
            </svg>
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ========================================
     CREW PRESENTATION — SCOPED CSS VARIABLES
     ======================================== */

  body {
    overflow: hidden;
    background: var(--color-bg);
    --crew-accent: #6366f1;
    --crew-accent-light: #818cf8;
    --crew-accent-deep: #4f46e5;
    --crew-teal: #2dd4bf;
  }

  .presentation {
    position: relative;
    z-index: 1;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  /* ========================================
     SLIDES
     ======================================== */

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    will-change: transform, opacity;
  }

  .slide-active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: all;
  }

  .slide-exit-left {
    opacity: 0;
    transform: translateX(-60px);
    pointer-events: none;
  }

  .slide-content {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    position: relative;
  }

  /* ========================================
     NAVIGATION
     ======================================== */

  .nav-arrow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    background: rgba(255, 253, 247, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-text);
    transition: all 0.25s ease;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .nav-arrow:hover {
    background: var(--crew-accent);
    color: white;
    border-color: var(--crew-accent);
