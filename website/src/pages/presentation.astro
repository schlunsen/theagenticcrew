  let audioEnabled = true;
  let audioVolume = 0.8;
  let currentAudio: HTMLAudioElement | null = null;
  let audioProgressInterval: number | null = null;

  // Preload audio for all slides
  const slideAudioCache: Record<number, HTMLAudioElement> = {};

  function preloadSlideAudio(slideIndex: number) {
    const slideNum = slideIndex + 1;
    const paddedNum = slideNum.toString().padStart(2, '0');
    const audioUrl = `/presentation-audio/slide-${paddedNum}.mp3`;
    if (slideAudioCache[slideIndex]) return;

    const audio = new Audio();
    audio.preload = 'auto';
    audio.src = audioUrl;
    audio.volume = audioVolume;
    // Don't fail silently if file doesn't exist yet
    audio.addEventListener('error', () => {
      delete slideAudioCache[slideIndex];
    });
    audio.addEventListener('canplaythrough', () => {
      slideAudioCache[slideIndex] = audio;
    }, { once: true });
    slideAudioCache[slideIndex] = audio;
  }

  // Preload all slides
  for (let i = 0; i < totalSlides; i++) {
    preloadSlideAudio(i);
  }

  const FADE_DURATION = 600; // ms for fade out/in
  const FADE_STEPS = 30;

  function fadeOutAudio(audio: HTMLAudioElement): Promise<void> {
    return new Promise((resolve) => {
      const startVol = audio.volume;
      if (startVol === 0 || audio.paused) {
        resolve();
        return;
      }
      const step = startVol / FADE_STEPS;
      const interval = FADE_DURATION / FADE_STEPS;
      const timer = setInterval(() => {
        const newVol = Math.max(0, audio.volume - step);
        audio.volume = newVol;
        if (newVol <= 0.01) {
          clearInterval(timer);
          audio.pause();
          audio.volume = startVol; // restore for next play
          resolve();
        }
      }, interval);
    });
  }

  function fadeInAudio(audio: HTMLAudioElement, targetVol: number) {
    audio.volume = 0;
    audio.play().catch(() => {
      console.log('Audio autoplay blocked. Click the speaker icon to enable.');
    });
    const step = targetVol / FADE_STEPS;
    const interval = FADE_DURATION / FADE_STEPS;
    const timer = setInterval(() => {
      const newVol = Math.min(targetVol, audio.volume + step);
      audio.volume = newVol;
      if (newVol >= targetVol - 0.01) {
        audio.volume = targetVol;
        clearInterval(timer);
      }
    }, interval);
  }

  function stopCurrentAudio() {
    if (currentAudio) {
      // Quick fade out if still playing
      const audio = currentAudio;
      const startVol = audio.volume;
      const step = startVol / 15; // faster fade for stop (300ms)
      const timer = setInterval(() => {
        const newVol = Math.max(0, audio.volume - step);
        audio.volume = newVol;
        if (newVol <= 0.01) {
          clearInterval(timer);
          audio.pause();
          audio.currentTime = 0;
          audio.volume = startVol;
        }
      }, 20);
      currentAudio = null;
    }
    if (audioProgressInterval) {
      clearInterval(audioProgressInterval);
      audioProgressInterval = null;
    }
    audioProgressBar.style.width = '0%';
  }

  function playSlideAudio(slideIndex: number) {
    if (!audioEnabled) {
      stopCurrentAudio();
      return;
    }

    const nextAudio = slideAudioCache[slideIndex];
    if (!nextAudio) {
      stopCurrentAudio();
      return;
    }

    // If something is currently playing, fade it out first then fade in the new one
    if (currentAudio && !currentAudio.paused) {
      const prevAudio = currentAudio;
      currentAudio = null;
      if (audioProgressInterval) {
        clearInterval(audioProgressInterval);
        audioProgressInterval = null;
      }

      fadeOutAudio(prevAudio).then(() => {
        prevAudio.currentTime = 0;
        startNewAudio(nextAudio, slideIndex);
      });
    } else {
      stopCurrentAudio();
      // Small delay so the slide transition finishes first
      setTimeout(() => {
        startNewAudio(nextAudio, slideIndex);
      }, 300);
    }
  }

  function startNewAudio(audio: HTMLAudioElement, slideIndex: number) {
    if (!audioEnabled) return;

    audio.currentTime = 0;
    currentAudio = audio;

    // Fade in
    fadeInAudio(audio, audioVolume);

    // Update progress bar
    audioProgressInterval = window.setInterval(() => {
      if (audio.duration && !audio.paused) {
        const pct = (audio.currentTime / audio.duration) * 100;
        audioProgressBar.style.width = `${pct}%`;
      }
    }, 200);

    audio.addEventListener('ended', () => {
      audioProgressBar.style.width = '100%';
      setTimeout(() => { audioProgressBar.style.width = '0%'; }, 500);
      if (audioProgressInterval) clearInterval(audioProgressInterval);
    }, { once: true });
  }

  // Toggle mute
  audioToggle.addEventListener('click', () => {
    audioEnabled = !audioEnabled;
    audioToggle.classList.toggle('muted', !audioEnabled);

    if (!audioEnabled) {
      stopCurrentAudio();
    } else {
      // Resume playing current slide's audio
      playSlideAudio(currentSlide);
    }
  });

  // Volume control
  volumeSlider.addEventListener('input', () => {
    audioVolume = parseInt(volumeSlider.value) / 100;
    if (currentAudio) {
      currentAudio.volume = audioVolume;
    }
    if (audioVolume === 0) {
      audioToggle.classList.add('muted');
      audioEnabled = false;
    } else if (!audioEnabled) {
      audioEnabled = true;
      audioToggle.classList.remove('muted');
    }
  });

  // 'A' key to toggle audio
  document.addEventListener('keydown', (e) => {
    if (e.key === 'a' || e.key === 'A') {
      audioToggle.click();
    }
  });

  // Export audio function so goToSlide can call it
  (window as any).__playSlideAudio = playSlideAudio;

  // ========================================
  // INITIALIZE
  // ========================================

  // Set initial notes
  const firstSlide = slides[0] as HTMLElement;
  if (firstSlide && firstSlide.dataset.notes) {
    notesContent.textContent = firstSlide.dataset.notes;
  }

  // Play audio for the first slide after user interaction
  document.addEventListener('click', () => {
    if (audioEnabled && !currentAudio) {
      playSlideAudio(0);
    }
  }, { once: true });

  document.addEventListener('keydown', () => {
    if (audioEnabled && !currentAudio) {
      playSlideAudio(0);
    }
  }, { once: true });
</script>
