<style>
  /* ========================================
     PRESENTATION GLOBAL STYLES
     ======================================== */

  body {
    overflow: hidden;
    background: var(--color-bg);
  }

  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .presentation {
    position: relative;
    z-index: 1;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  /* ========================================
     SLIDES
     ======================================== */

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    will-change: transform, opacity;
  }

  .slide-active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: all;
  }

  .slide-exit-left {
    opacity: 0;
    transform: translateX(-60px);
    pointer-events: none;
  }

  .slide-content {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    position: relative;
  }

  /* ========================================
     NAVIGATION
     ======================================== */

  .nav-arrow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    background: rgba(255, 253, 247, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-text);
    transition: all 0.25s ease;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .nav-arrow:hover {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(232, 150, 62, 0.3);
  }

  .nav-prev { left: 1.5rem; }
  .nav-next { right: 1.5rem; }

  /* ========================================
     PROGRESS DOTS
     ======================================== */

  .progress-dots {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    gap: 0.6rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 253, 247, 0.8);
    backdrop-filter: blur(8px);
    border-radius: 20px;
    border: 1px solid var(--color-border-light);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid var(--color-accent);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .dot:hover {
    background: rgba(232, 150, 62, 0.3);
  }

  .dot.active {
    background: var(--color-accent);
    box-shadow: 0 0 8px rgba(232, 150, 62, 0.4);
  }

  /* ========================================
     SLIDE COUNTER
     ======================================== */

  .slide-counter {
    position: fixed;
    top: 1.5rem;
    right: 2rem;
    z-index: 100;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* ========================================
     AUDIO CONTROLS
     ======================================== */

  .audio-controls {
    position: fixed;
    top: 1.5rem;
    left: 2rem;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    padding: 0.35rem 0.75rem;
    transition: opacity 0.3s;
  }

  .audio-controls:hover {
    opacity: 1 !important;
  }

  .audio-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-accent);
    display: flex;
    align-items: center;
    padding: 0.2rem;
    border-radius: 50%;
    transition: background 0.2s;
  }

  .audio-toggle:hover {
    background: rgba(232, 150, 62, 0.1);
  }

  .audio-toggle.muted .audio-on { display: none; }
  .audio-toggle.muted .audio-off { display: block !important; }
  .audio-toggle:not(.muted) .audio-on { display: block; }
  .audio-toggle:not(.muted) .audio-off { display: none !important; }

  .volume-slider {
    width: 60px;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--color-border);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  .volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    cursor: pointer;
    border: 2px solid white;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }

  .volume-slider::-moz-range-thumb {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    cursor: pointer;
    border: 2px solid white;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }

  .audio-progress {
    width: 40px;
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .audio-progress-bar {
    height: 100%;
    width: 0%;
    background: var(--color-accent);
    border-radius: 2px;
    transition: width 0.3s linear;
  }

  @media (max-width: 768px) {
    .audio-controls {
      top: auto;
      bottom: 4rem;
      left: 50%;
      transform: translateX(-50%);
    }
  }

  /* ========================================
     PRESENTER NOTES
     ======================================== */

  .presenter-notes {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: rgba(26, 32, 64, 0.95);
    backdrop-filter: blur(12px);
    color: #f0ead6;
    padding: 1.5rem 2rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.6;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    max-height: 30vh;
    overflow-y: auto;
  }

  .presenter-notes.visible {
    transform: translateY(0);
  }

  .notes-inner::before {
    content: 'PRESENTER NOTES';
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  /* ========================================
     TYPOGRAPHY
     ======================================== */

  .slide-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-pirate-teal);
    margin-bottom: 1rem;
  }

  .slide-main-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-deep) 35%, var(--color-pirate-teal) 75%, var(--color-accent) 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 8s ease-in-out infinite;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .slide-subtitle-big {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .slide-date {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .slide-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .slide-heading-big {
    font-size: clamp(2.5rem, 5vw, 4rem);
    background: linear-gradient(135deg, var(--color-accent), var(--color-pirate-teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
