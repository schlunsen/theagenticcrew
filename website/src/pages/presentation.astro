  audioToggle.addEventListener('click', () => {
    audioEnabled = !audioEnabled;
    audioToggle.classList.toggle('muted', !audioEnabled);

    if (!audioEnabled) {
      stopCurrentAudio();
    } else {
      // Resume playing current slide's audio
      playSlideAudio(currentSlide);
