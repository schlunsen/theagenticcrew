  }

  .slide-tagline {
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-text-muted);
    font-size: 1.15rem;
    margin-bottom: 2rem;
    width: 100%;
  }

  .slide-body {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    text-align: center;
  }

  .slide-blockquote {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
