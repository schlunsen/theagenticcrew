    font-weight: 600;
  }

  /* ========================================
     SLIDE LAYOUTS
     ======================================== */

  .slide-title-layout {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
  }

