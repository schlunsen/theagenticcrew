    <!-- ============ SLIDE 11: Guardrails for Hostile Agents ============ -->
    <section class="slide" data-index="10" data-notes="When your agent IS the threat model, guardrails become existential. Never run on production. Require written authorization. Human-verify every finding.">
      <div class="slide-content slide-center-layout">
        <h2 class="slide-heading" data-i18n="slide11-heading">When Agents Attack (Responsibly)</h2>
        <div class="hostile-guardrails">
          <div class="guardrail-warning">
            <div class="failure-icon">
              <svg viewBox="0 0 40 40" width="36" height="36" fill="none" stroke="#d94f4f" stroke-width="1.5">
                <path d="M10 30l10-20 10 20z" />
