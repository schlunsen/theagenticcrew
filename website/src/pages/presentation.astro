    level.addEventListener('click', () => {
      spectrumLevels.forEach(l => l.classList.remove('active-level'));
      level.classList.add('active-level');
      const lvl = parseInt(level.dataset.level || '0');
      const fillWidths = ['18%', '40%', '62%', '90%'];
      if (spectrumFill) spectrumFill.style.width = fillWidths[lvl];
      if (spectrumDesc) {
        const lang = currentLang;
        spectrumDesc.textContent = (lang === 'es' && level.dataset.descEs)
          ? level.dataset.descEs
          : level.dataset.desc || '';
      }
      // Show/hide pointer
      spectrumLevels.forEach(l => {
