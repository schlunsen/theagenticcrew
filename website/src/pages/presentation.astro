---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Agentic Crew — Presentation">
  <canvas id="bg-canvas"></canvas>

  <div class="presentation" id="presentation">
    <!-- Slide Counter -->
    <div class="slide-counter" id="slide-counter">1 / 11</div>

    <!-- Progress Dots -->
    <div class="progress-dots" id="progress-dots">
      {Array.from({ length: 11 }).map((_, i) => (
        <button class={`dot ${i === 0 ? 'active' : ''}`} data-slide={i} aria-label={`Go to slide ${i + 1}`}></button>
      ))}
    </div>

    <!-- Navigation Arrows -->
    <button class="nav-arrow nav-prev" id="nav-prev" aria-label="Previous slide">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M15 18l-6-6 6-6" />
      </svg>
    </button>
    <button class="nav-arrow nav-next" id="nav-next" aria-label="Next slide">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M9 18l6-6-6-6" />
      </svg>
    </button>

    <!-- Audio Controls -->
    <div class="audio-controls" id="audio-controls">
      <button class="audio-toggle" id="audio-toggle" aria-label="Toggle narration audio" title="Toggle narration (A)">
        <svg class="audio-icon audio-on" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
        </svg>
        <svg class="audio-icon audio-off" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="display:none">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
          <line x1="23" y1="9" x2="17" y2="15" />
          <line x1="17" y1="9" x2="23" y2="15" />
        </svg>
      </button>
      <input type="range" class="volume-slider" id="volume-slider" min="0" max="100" value="80" aria-label="Narration volume" title="Volume" />
      <div class="audio-progress" id="audio-progress">
        <div class="audio-progress-bar" id="audio-progress-bar"></div>
      </div>
    </div>

    <!-- Presenter Notes Overlay -->
    <div class="presenter-notes" id="presenter-notes">
      <div class="notes-inner" id="notes-content"></div>
    </div>

    <!-- ============ SLIDE 1: Title ============ -->
    <section class="slide slide-active" data-index="0" data-notes="Welcome everyone. This is a talk about how software engineering is changing in the age of AI agents.">
      <div class="slide-content slide-title-layout">
        <div class="title-wheel" aria-hidden="true">
          <svg viewBox="0 0 200 200" width="280" height="280" fill="none" stroke="currentColor" class="ships-wheel">
            <circle cx="100" cy="100" r="70" stroke-width="4" opacity="0.3" />
            <circle cx="100" cy="100" r="50" stroke-width="3" opacity="0.2" />
            <circle cx="100" cy="100" r="12" stroke-width="3" opacity="0.4" />
            <!-- Spokes -->
            {Array.from({ length: 8 }).map((_, i) => {
              const angle = (i * 45) * Math.PI / 180;
              const x1 = 100 + Math.cos(angle) * 12;
              const y1 = 100 + Math.sin(angle) * 12;
              const x2 = 100 + Math.cos(angle) * 70;
              const y2 = 100 + Math.sin(angle) * 70;
              return <line x1={x1.toString()} y1={y1.toString()} x2={x2.toString()} y2={y2.toString()} stroke-width="3" opacity="0.3" />;
            })}
            <!-- Handles -->
            {Array.from({ length: 8 }).map((_, i) => {
              const angle = (i * 45) * Math.PI / 180;
              const cx = 100 + Math.cos(angle) * 82;
              const cy = 100 + Math.sin(angle) * 82;
              return <circle cx={cx.toString()} cy={cy.toString()} r="6" stroke-width="2.5" opacity="0.3" />;
            })}
          </svg>
        </div>
        <div id="lottie-title-glow" class="lottie-title-glow"></div>
        <p class="slide-eyebrow">A Book by Rasmus Bornhoft Schlunsen</p>
        <h1 class="slide-main-title">The Agentic<br/>Crew</h1>
        <p class="slide-subtitle-big">Engineering in the Age of AI Agents</p>
        <p class="slide-date">March 2026</p>
      </div>
    </section>

    <!-- ============ SLIDE 2: The Ground Is Shifting ============ -->
    <section class="slide" data-index="1" data-notes="For two decades, the feedback loop was simple: write code, run it, ship it. AI agents are fundamentally changing that loop.">
      <div class="slide-content slide-quote-layout">
        <h2 class="slide-heading">The Ground Is Shifting</h2>
        <blockquote class="slide-blockquote reveal-text" id="quote-slide2">
          "For twenty years, being a software engineer meant one thing: you open an editor, you write code, you ship it. <em>That loop is breaking.</em>"
        </blockquote>
        <div class="agent-loop-svg" aria-hidden="true">
          <svg viewBox="0 0 500 200" width="500" height="200" fill="none">
            <!-- Keyboard to agent loop -->
            <g class="loop-group">
              <!-- Keyboard icon -->
              <rect x="20" y="70" width="80" height="50" rx="6" stroke="var(--color-accent)" stroke-width="2" opacity="0.6" />
              <line x1="35" y1="85" x2="55" y2="85" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4" />
              <line x1="35" y1="95" x2="85" y2="95" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4" />
              <line x1="45" y1="105" x2="75" y2="105" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4" />
              <!-- Arrow from keyboard -->
              <path d="M110 95 L150 95" stroke="var(--color-text-muted)" stroke-width="1.5" stroke-dasharray="4 4" class="flow-arrow" />
              <polygon points="150,90 160,95 150,100" fill="var(--color-text-muted)" opacity="0.5" />
              <!-- Agent loop circle -->
              <circle cx="300" cy="95" r="75" stroke="var(--color-pirate-teal)" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.3" class="loop-circle" />
              <!-- Think -->
              <text x="300" y="45" text-anchor="middle" fill="var(--color-pirate-teal)" font-size="13" font-family="var(--font-mono)" opacity="0.8">Think</text>
              <!-- Act -->
              <text x="395" y="100" text-anchor="middle" fill="var(--color-accent)" font-size="13" font-family="var(--font-mono)" opacity="0.8">Act</text>
              <!-- Observe -->
              <text x="300" y="155" text-anchor="middle" fill="var(--color-pirate-teal)" font-size="13" font-family="var(--font-mono)" opacity="0.8">Observe</text>
              <!-- Adjust -->
              <text x="205" y="100" text-anchor="middle" fill="var(--color-accent)" font-size="13" font-family="var(--font-mono)" opacity="0.8">Adjust</text>
              <!-- Circular arrows -->
              <path d="M300 22 A73 73 0 0 1 373 95" stroke="var(--color-pirate-teal)" stroke-width="1.5" fill="none" class="loop-path loop-path-1" />
              <path d="M373 95 A73 73 0 0 1 300 168" stroke="var(--color-accent)" stroke-width="1.5" fill="none" class="loop-path loop-path-2" />
              <path d="M300 168 A73 73 0 0 1 227 95" stroke="var(--color-pirate-teal)" stroke-width="1.5" fill="none" class="loop-path loop-path-3" />
              <path d="M227 95 A73 73 0 0 1 300 22" stroke="var(--color-accent)" stroke-width="1.5" fill="none" class="loop-path loop-path-4" />
              <!-- Arrow tips on the arcs -->
              <polygon points="368,80 378,95 368,95" fill="var(--color-pirate-teal)" opacity="0.6" />
              <polygon points="315,165 300,168 305,155" fill="var(--color-accent)" opacity="0.6" />
            </g>
          </svg>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 3: The Craft Is Molting ============ -->
    <section class="slide" data-index="2" data-notes="The craft is evolving. The mechanical parts are being automated, but the judgment, taste, and architectural thinking are more important than ever.">
      <div class="slide-content slide-image-quote-layout">
        <div class="slide-text-side">
          <h2 class="slide-heading">The Craft Is Molting</h2>
          <blockquote class="slide-blockquote">
            "The craft isn't dying. It's molting. The outer shell -- the keystrokes, the syntax, the boilerplate -- is falling away. But the animal underneath? The part that knows <em>what to build</em> and <em>why</em>? That part is more alive than ever."
          </blockquote>
        </div>
        <div class="slide-image-side">
          <img src="/illustrations/foreword-molting.jpg" alt="A cocoon cracking open with light emerging" class="oval-vignette slide-illustration" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 4: What Is an Agent? ============ -->
    <section class="slide" data-index="3" data-notes="Agents exist on a spectrum. Most practical work today happens at the tool-using agent level, where the agent can call tools, read files, and iterate.">
      <div class="slide-content slide-center-layout">
        <h2 class="slide-heading">What Is an Agent?</h2>
        <p class="slide-body">The spectrum of AI assistance in software engineering:</p>
        <div class="spectrum-container" id="spectrum">
          <div class="spectrum-bar">
            <div class="spectrum-fill" id="spectrum-fill"></div>
          </div>
          <div class="spectrum-levels">
            <button class="spectrum-level" data-level="0" data-desc="Tab-completion suggestions. Predicts the next few tokens.">
              <div class="spectrum-icon">
                <svg viewBox="0 0 40 40" width="40" height="40" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5">
                  <rect x="5" y="10" width="30" height="20" rx="3" />
                  <path d="M12 20h6m-3-3v6" opacity="0.5" />
                </svg>
              </div>
              <span>Autocomplete</span>
            </button>
            <button class="spectrum-level" data-level="1" data-desc="Inline code suggestions. Understands context within a file.">
              <div class="spectrum-icon">
                <svg viewBox="0 0 40 40" width="40" height="40" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5">
                  <rect x="5" y="5" width="30" height="30" rx="3" />
                  <path d="M12 15l4 5-4 5m8 0h6" opacity="0.6" />
                </svg>
              </div>
              <span>Copilot</span>
            </button>
            <button class="spectrum-level active-level" data-level="2" data-desc="Can read files, run commands, call APIs, and iterate on results. This is where most practical work happens today.">
              <div class="spectrum-icon">
                <svg viewBox="0 0 40 40" width="40" height="40" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
                  <circle cx="20" cy="15" r="8" />
                  <path d="M8 35c0-6 5-10 12-10s12 4 12 10" />
                  <path d="M30 12l6-2m-6 6l6 2" stroke="var(--color-pirate-teal)" />
                </svg>
              </div>
              <span>Tool-Using Agent</span>
              <div class="spectrum-pointer">Most practical work happens here</div>
            </button>
            <button class="spectrum-level" data-level="3" data-desc="Fully autonomous operation. Plans, executes, and self-corrects across entire projects with minimal human input.">
              <div class="spectrum-icon">
                <svg viewBox="0 0 40 40" width="40" height="40" fill="none" stroke="var(--color-text-muted)" stroke-width="1.5">
                  <circle cx="20" cy="20" r="14" stroke-dasharray="4 3" />
                  <circle cx="20" cy="20" r="6" />
                  <path d="M20 6v4m0 20v4M6 20h4m20 0h4" opacity="0.5" />
                </svg>
              </div>
              <span>Autonomous Agent</span>
            </button>
          </div>
          <div class="spectrum-desc" id="spectrum-desc">Can read files, run commands, call APIs, and iterate on results. This is where most practical work happens today.</div>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 5: The Rain Man Analogy ============ -->
    <section class="slide" data-index="4" data-notes="Think of it like Rain Man. Tom Cruise provides the direction and judgment. Dustin Hoffman provides extraordinary capability but needs guidance.">
      <div class="slide-content slide-two-panel-layout">
        <h2 class="slide-heading slide-heading-full">The Rain Man Analogy</h2>
        <p class="slide-tagline">"You're Tom Cruise. The agent is Dustin Hoffman."</p>
        <div class="two-panels">
          <div class="panel panel-captain">
            <h3>The Captain (You)</h3>
            <ul>
              <li>Direction &amp; vision</li>
              <li>Judgment &amp; taste</li>
              <li>Domain expertise</li>
              <li>Architectural decisions</li>
            </ul>
          </div>
          <div class="panel-divider">
            <svg viewBox="0 0 4 100" width="4" height="100" fill="none">
              <line x1="2" y1="0" x2="2" y2="100" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4 4" />
            </svg>
          </div>
          <div class="panel panel-agent">
            <h3>The Agent (Crew)</h3>
            <ul>
              <li>Speed &amp; throughput</li>
              <li>Breadth of knowledge</li>
              <li>Tireless execution</li>
              <li>Pattern recognition</li>
            </ul>
          </div>
        </div>
        <div class="slide-image-below">
          <img src="/illustrations/ch03-rain-man.jpg" alt="Captain and crew illustration" class="oval-vignette slide-illustration-small" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 6: Three Capabilities ============ -->
    <section class="slide" data-index="5" data-notes="These are the three core capabilities that make an agent an agent: planning, tool use, and iteration. Without any one of these, you just have a chatbot.">
      <div class="slide-content slide-center-layout">
        <h2 class="slide-heading">Three Core Capabilities</h2>
        <div class="capability-cards" id="capability-cards">
          <div class="cap-card" data-cap="planning">
            <div class="cap-card-front">
              <svg viewBox="0 0 60 60" width="60" height="60" fill="none" stroke="var(--color-pirate-teal)" stroke-width="1.5">
                <circle cx="30" cy="30" r="24" stroke-dasharray="4 3" opacity="0.4" />
                <circle cx="30" cy="30" r="3" fill="var(--color-pirate-teal)" opacity="0.6" />
                <path d="M30 6v6m0 36v6M6 30h6m36 0h6" opacity="0.5" />
                <path d="M30 10l2 18h-4z" fill="var(--color-pirate-teal)" opacity="0.3" />
              </svg>
              <h3>Planning</h3>
              <p class="cap-hint">Click to reveal</p>
            </div>
            <div class="cap-card-back">
              <p>Breaking down complex tasks into steps. Understanding dependencies, ordering work, and deciding what to do first.</p>
            </div>
          </div>
          <div class="cap-card" data-cap="tools">
            <div class="cap-card-front">
              <svg viewBox="0 0 60 60" width="60" height="60" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
                <path d="M20 40l-8 8a3 3 0 004 4l8-8" />
                <path d="M24 36l12-12" stroke-width="2" />
                <circle cx="42" cy="18" r="10" stroke-dasharray="3 3" opacity="0.4" />
                <path d="M38 14l4 4m0-4l-4 4" opacity="0.6" />
              </svg>
              <h3>Tool Use</h3>
              <p class="cap-hint">Click to reveal</p>
            </div>
            <div class="cap-card-back">
              <p>Reading files, running commands, calling APIs, writing code. The agent's hands in the real world.</p>
            </div>
          </div>
          <div class="cap-card" data-cap="iteration">
            <div class="cap-card-front">
              <svg viewBox="0 0 60 60" width="60" height="60" fill="none" stroke="var(--color-accent-deep)" stroke-width="1.5">
                <path d="M42 22A15 15 0 1118 30" />
                <polygon points="18,24 18,36 12,30" fill="var(--color-accent-deep)" opacity="0.4" />
                <path d="M18 38A15 15 0 1142 30" />
                <polygon points="42,36 42,24 48,30" fill="var(--color-accent-deep)" opacity="0.4" />
              </svg>
              <h3>Iteration</h3>
              <p class="cap-hint">Click to reveal</p>
            </div>
            <div class="cap-card-back">
              <p>Running code, seeing errors, fixing them, and trying again. The observe-adjust loop that makes agents powerful.</p>
            </div>
          </div>
        </div>
        <div id="lottie-capabilities" class="lottie-capabilities"></div>
      </div>
    </section>

    <!-- ============ SLIDE 7: When Agents Fail ============ -->
    <section class="slide" data-index="6" data-notes="Understanding failure modes is critical. These are the four most common ways agents go wrong, and how to mitigate each one.">
      <div class="slide-content slide-failures-layout">
        <h2 class="slide-heading">When Agents Fail</h2>
        <div class="failure-cards" id="failure-cards">
          <div class="failure-card" data-delay="0">
            <div class="failure-icon">
              <svg viewBox="0 0 40 40" width="36" height="36" fill="none" stroke="#d94f4f" stroke-width="1.5">
                <circle cx="20" cy="20" r="15" />
                <path d="M12 12l16 16M28 12l-16 16" opacity="0.5" />
              </svg>
            </div>
            <h3>Scope Creep</h3>
            <p class="failure-desc">Agent expands beyond the task, refactoring code you didn't ask it to touch.</p>
            <p class="failure-fix">Fix: Small, focused prompts. One task at a time.</p>
          </div>
          <div class="failure-card" data-delay="1">
            <div class="failure-icon">
              <svg viewBox="0 0 40 40" width="36" height="36" fill="none" stroke="#d94f4f" stroke-width="1.5">
                <path d="M10 30l10-20 10 20z" />
                <line x1="20" y1="18" x2="20" y2="24" />
                <circle cx="20" cy="27" r="1" fill="#d94f4f" />
              </svg>
            </div>
            <h3>Hallucinated APIs</h3>
            <p class="failure-desc">Agent invents function signatures or library methods that don't exist.</p>
            <p class="failure-fix">Fix: Always run tests. Pin dependency docs in context.</p>
          </div>
          <div class="failure-card" data-delay="2">
            <div class="failure-icon">
              <svg viewBox="0 0 40 40" width="36" height="36" fill="none" stroke="#d94f4f" stroke-width="1.5">
                <circle cx="20" cy="20" r="15" />
                <path d="M14 16c0-2 3-4 6-4s6 2 6 4" />
                <circle cx="15" cy="22" r="1.5" fill="#d94f4f" />
                <circle cx="25" cy="22" r="1.5" fill="#d94f4f" />
                <path d="M14 28c2 2 4 3 6 3s4-1 6-3" />
              </svg>
            </div>
            <h3>Overconfidence</h3>
            <p class="failure-desc">Agent presents wrong answers with certainty. No hedging, no doubt.</p>
            <p class="failure-fix">Fix: Verify everything. Trust but verify.</p>
          </div>
          <div class="failure-card" data-delay="3">
            <div class="failure-icon">
              <svg viewBox="0 0 40 40" width="36" height="36" fill="none" stroke="#d94f4f" stroke-width="1.5">
                <rect x="8" y="8" width="24" height="24" rx="3" stroke-dasharray="4 3" />
                <path d="M14 20h12M14 15h8M14 25h10" opacity="0.4" />
                <path d="M30 10l-20 20" stroke-width="2" opacity="0.6" />
              </svg>
            </div>
            <h3>Context Loss</h3>
            <p class="failure-desc">Agent forgets earlier instructions as the conversation grows long.</p>
            <p class="failure-fix">Fix: Fresh sessions. Project rules files. Keep context lean.</p>
          </div>
        </div>
        <div class="slide-image-accent">
          <img src="/illustrations/ch13-storm.jpg" alt="Storm clouds illustration" class="oval-vignette slide-illustration-tiny" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 8: The Engineering Toolkit ============ -->
    <section class="slide" data-index="7" data-notes="These five practices form the engineering toolkit for working with agents effectively. Each one reinforces the others.">
      <div class="slide-content slide-center-layout">
        <h2 class="slide-heading">The Engineering Toolkit</h2>
        <div class="pipeline" id="pipeline">
          <div class="pipeline-node" data-node="guardrails" data-info="Constraints that keep agents on track: linters, type checkers, pre-commit hooks, and approval gates.">
            <div class="pipeline-icon">
              <svg viewBox="0 0 44 44" width="44" height="44" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
                <rect x="6" y="10" width="32" height="24" rx="4" />
                <path d="M6 18h32" />
                <path d="M16 26h12" opacity="0.5" />
              </svg>
            </div>
            <span>Guardrails</span>
          </div>
          <div class="pipeline-connector"><div class="connector-line"></div></div>
          <div class="pipeline-node" data-node="git" data-info="Version control as a safety net: branches for isolation, diffs for review, revert as your undo button.">
            <div class="pipeline-icon">
              <svg viewBox="0 0 44 44" width="44" height="44" fill="none" stroke="var(--color-pirate-teal)" stroke-width="1.5">
                <circle cx="22" cy="12" r="4" />
                <circle cx="14" cy="32" r="4" />
                <circle cx="30" cy="32" r="4" />
                <path d="M22 16v6l-8 6m8-6l8 6" />
              </svg>
            </div>
            <span>Git</span>
          </div>
          <div class="pipeline-connector"><div class="connector-line"></div></div>
          <div class="pipeline-node" data-node="sandboxes" data-info="Isolated environments where agents can safely experiment without affecting production.">
            <div class="pipeline-icon">
              <svg viewBox="0 0 44 44" width="44" height="44" fill="none" stroke="var(--color-accent-deep)" stroke-width="1.5">
                <rect x="8" y="8" width="28" height="28" rx="4" stroke-dasharray="4 3" />
                <rect x="14" y="14" width="16" height="16" rx="2" />
              </svg>
            </div>
            <span>Sandboxes</span>
          </div>
          <div class="pipeline-connector"><div class="connector-line"></div></div>
          <div class="pipeline-node" data-node="testing" data-info="Tests as the feedback loop: the agent runs tests, sees failures, and iterates. Tests replace human eyes.">
            <div class="pipeline-icon">
              <svg viewBox="0 0 44 44" width="44" height="44" fill="none" stroke="var(--color-pirate-teal)" stroke-width="1.5">
                <path d="M12 22l6 6 14-14" stroke-width="2" />
                <circle cx="22" cy="22" r="16" stroke-dasharray="4 3" opacity="0.4" />
              </svg>
            </div>
            <span>Testing</span>
          </div>
          <div class="pipeline-connector"><div class="connector-line"></div></div>
          <div class="pipeline-node" data-node="conventions" data-info="Convention over configuration: project rules, naming patterns, and structure that agents can follow without being told.">
            <div class="pipeline-icon">
              <svg viewBox="0 0 44 44" width="44" height="44" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
                <path d="M10 10h24v24H10z" opacity="0.3" />
                <path d="M16 16h12M16 22h8M16 28h10" />
              </svg>
            </div>
            <span>Conventions</span>
          </div>
        </div>
        <div class="pipeline-info" id="pipeline-info">Click any node to learn more</div>
      </div>
    </section>

    <!-- ============ SLIDE 9: CCT — Building My Own Control Plane ============ -->
    <section class="slide" data-index="8" data-notes="I built CCT (Clovr Code Terminal) as a way to practice agentic engineering myself. It's a browser-based control plane for running multiple Claude agent sessions. Built in Go and Vue, single binary, no dependencies.">
      <div class="slide-content slide-cct-layout">
        <h2 class="slide-heading">I Built the Control Plane</h2>
        <p class="slide-subtitle-cct">Clovr Code Terminal (CCT) — practicing what I preach</p>
        <div class="cct-showcase">
