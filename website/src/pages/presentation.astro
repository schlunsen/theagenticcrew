  // ========================================
  // BACKGROUND MUSIC SYSTEM
  // ========================================

  const bgMusic = new Audio('/presentation-audio/bg-music.mp3');
  bgMusic.loop = true;
  bgMusic.volume = 0;
  bgMusic.preload = 'auto';

  const BG_MUSIC_HIGH = 0.35;  // Volume when no narration playing
  const BG_MUSIC_LOW = 0.15;   // Volume when narration is playing (ducked)
  const BG_FADE_DURATION = 800; // ms for music volume transitions
  const BG_FADE_STEPS = 40;
  let bgMusicStarted = false;
  let bgFadeTimer: number | null = null;

  function fadeBgMusicTo(targetVol: number, duration: number = BG_FADE_DURATION): Promise<void> {
    return new Promise((resolve) => {
      if (bgFadeTimer) clearInterval(bgFadeTimer);
      const startVol = bgMusic.volume;
      if (Math.abs(startVol - targetVol) < 0.005) {
        bgMusic.volume = targetVol;
        resolve();
        return;
      }
      const steps = BG_FADE_STEPS;
      const stepSize = (targetVol - startVol) / steps;
      const interval = duration / steps;
      let currentStep = 0;
      bgFadeTimer = window.setInterval(() => {
        currentStep++;
        const newVol = Math.max(0, Math.min(1, startVol + stepSize * currentStep));
        bgMusic.volume = newVol;
        if (currentStep >= steps) {
          clearInterval(bgFadeTimer!);
          bgFadeTimer = null;
          bgMusic.volume = targetVol;
          resolve();
        }
      }, interval);
    });
  }

  function startBgMusic() {
    if (bgMusicStarted) return;
    bgMusicStarted = true;
    bgMusic.volume = 0;
    bgMusic.play().then(() => {
      fadeBgMusicTo(BG_MUSIC_HIGH, 2000); // 2s fade-in on page start
    }).catch(() => {
      bgMusicStarted = false;
      console.log('Background music autoplay blocked');
    });
  }

  function duckBgMusic() {
    if (!bgMusicStarted) return;
    fadeBgMusicTo(BG_MUSIC_LOW);
  }

  function unduckBgMusic() {
    if (!bgMusicStarted) return;
    fadeBgMusicTo(BG_MUSIC_HIGH);
  }

  function stopBgMusic() {
    if (!bgMusicStarted) return;
    fadeBgMusicTo(0, 3000).then(() => { // 3s fade-out
      bgMusic.pause();
      bgMusicStarted = false;
    });
  }

  // Hook into narration: duck when narration starts, unduck when it ends
  const _origStartNewAudioBg = startNewAudio;
  startNewAudio = function(audio: HTMLAudioElement, slideIndex: number) {
    duckBgMusic();
    _origStartNewAudioBg(audio, slideIndex);

    audio.addEventListener('ended', () => {
      // If this is the last slide, wait 3s then fade out music entirely
      if (slideIndex >= totalSlides - 1) {
        setTimeout(() => {
          stopBgMusic();
        }, 3000);
      } else {
        unduckBgMusic();
      }
    }, { once: true });
  };

  // Hook into stop: unduck when narration is stopped manually
  const _origStopCurrentAudio = stopCurrentAudio;
  stopCurrentAudio = function() {
    _origStopCurrentAudio();
