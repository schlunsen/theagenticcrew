<style>
  /* ========================================
     PRESENTATION GLOBAL STYLES
     ======================================== */

  body {
    overflow: hidden;
    background: var(--color-bg);
  }

  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .presentation {
    position: relative;
    z-index: 1;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  /* ========================================
     SLIDES
     ======================================== */

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    opacity: 0;
    transform: translateX(60px);
    transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    will-change: transform, opacity;
  }

  .slide-active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: all;
  }

  .slide-exit-left {
    opacity: 0;
    transform: translateX(-60px);
    pointer-events: none;
  }

  .slide-content {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    position: relative;
  }

  /* ========================================
     NAVIGATION
     ======================================== */

  .nav-arrow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    background: rgba(255, 253, 247, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-text);
    transition: all 0.25s ease;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .nav-arrow:hover {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
    box-shadow: 0 4px 20px rgba(232, 150, 62, 0.3);
  }

  .nav-prev { left: 1.5rem; }
  .nav-next { right: 1.5rem; }

  /* ========================================
     PROGRESS DOTS
     ======================================== */

  .progress-dots {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    gap: 0.6rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 253, 247, 0.8);
    backdrop-filter: blur(8px);
    border-radius: 20px;
    border: 1px solid var(--color-border-light);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid var(--color-accent);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .dot:hover {
    background: rgba(232, 150, 62, 0.3);
  }

  .dot.active {
    background: var(--color-accent);
    box-shadow: 0 0 8px rgba(232, 150, 62, 0.4);
  }

  /* ========================================
     SLIDE COUNTER
     ======================================== */

  .slide-counter {
    position: fixed;
    top: 1.5rem;
    right: 2rem;
    z-index: 100;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  /* ========================================
     LANGUAGE SELECTOR
     ======================================== */

  .lang-selector {
    position: fixed;
    top: 1.5rem;
    right: 7rem;
    z-index: 100;
    display: flex;
    gap: 2px;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 3px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .lang-btn {
    background: transparent;
    border: none;
    padding: 0.25rem 0.65rem;
    border-radius: 16px;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted);
    transition: all 0.25s ease;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .lang-btn:hover {
    color: var(--color-text);
    background: rgba(232, 150, 62, 0.08);
  }

  .lang-btn.active {
    background: var(--color-accent);
    color: white;
    box-shadow: 0 1px 6px rgba(232, 150, 62, 0.35);
  }

  /* ========================================
     VOICE SELECTOR
     ======================================== */


  /* ========================================
     PLAY OVERLAY
     ======================================== */

  .play-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 253, 247, 0.85);
    backdrop-filter: blur(12px);
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }

  .play-overlay.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .play-overlay-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-accent);
    transition: transform 0.3s ease;
  }

  .play-overlay-btn:hover {
    transform: scale(1.08);
  }

  .play-overlay-btn:hover circle {
    opacity: 0.9;
  }

  .play-overlay-btn span {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  /* ========================================
     AUDIO CONTROLS
     ======================================== */

  .audio-controls {
    position: fixed;
    top: 1.5rem;
    left: 2rem;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    padding: 0.35rem 0.75rem;
    transition: opacity 0.3s;
  }

  .audio-controls:hover {
    opacity: 1 !important;
  }

  .audio-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-accent);
    display: flex;
    align-items: center;
    padding: 0.2rem;
    border-radius: 50%;
    transition: background 0.2s;
  }

  .audio-toggle:hover {
    background: rgba(232, 150, 62, 0.1);
  }

  .audio-toggle.muted .audio-on { display: none; }
  .audio-toggle.muted .audio-off { display: block !important; }
  .audio-toggle:not(.muted) .audio-on { display: block; }
  .audio-toggle:not(.muted) .audio-off { display: none !important; }

  .volume-slider {
    width: 60px;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--color-border);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }

  .volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    cursor: pointer;
    border: 2px solid white;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }

  .volume-slider::-moz-range-thumb {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-accent);
    cursor: pointer;
    border: 2px solid white;
    box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  }

  .audio-progress {
    width: 40px;
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .audio-progress-bar {
    height: 100%;
    width: 0%;
    background: var(--color-accent);
    border-radius: 2px;
    transition: width 0.3s linear;
  }

  @media (max-width: 768px) {
    .audio-controls {
      top: auto;
      bottom: 4rem;
      left: 50%;
      transform: translateX(-50%);
    }

    .lang-selector {
      top: auto;
      bottom: 6.5rem;
      right: auto;
      left: 50%;
      transform: translateX(-50%);
    }

  }

  /* ========================================
     PRESENTER NOTES
     ======================================== */

  .presenter-notes {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: rgba(26, 32, 64, 0.95);
    backdrop-filter: blur(12px);
    color: #f0ead6;
    padding: 1.5rem 2rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    line-height: 1.6;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    max-height: 30vh;
    overflow-y: auto;
  }

  .presenter-notes.visible {
    transform: translateY(0);
  }

  .notes-inner::before {
    content: 'PRESENTER NOTES';
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  /* ========================================
     TYPOGRAPHY
     ======================================== */

  .slide-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-pirate-teal);
    margin-bottom: 1rem;
  }

  .slide-main-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-deep) 35%, var(--color-pirate-teal) 75%, var(--color-accent) 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 8s ease-in-out infinite;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .slide-subtitle-big {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .slide-date {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .slide-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .slide-heading-big {
    font-size: clamp(2.5rem, 5vw, 4rem);
    background: linear-gradient(135deg, var(--color-accent), var(--color-pirate-teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .slide-heading-full {
    width: 100%;
    text-align: center;
  }

  .slide-tagline {
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-text-muted);
    font-size: 1.15rem;
    margin-bottom: 2rem;
    width: 100%;
  }

  .slide-body {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    text-align: center;
  }

  .slide-body-small {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  .slide-body-small a {
    color: var(--color-accent);
  }

  .slide-blockquote {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.7;
    color: var(--color-text);
    border-left: 3px solid var(--color-accent);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
  }

  .slide-blockquote em {
    color: var(--color-accent-deep);
    font-style: italic;
    font-weight: 600;
  }

  /* ========================================
     SLIDE LAYOUTS
     ======================================== */

  .slide-title-layout {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .slide-center-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .slide-quote-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
  }

  .slide-quote-layout .slide-blockquote {
    max-width: 700px;
    border-left: none;
    padding-left: 0;
    text-align: center;
    font-size: clamp(1.2rem, 2.5vw, 1.7rem);
  }

  .slide-image-quote-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .slide-image-quote-reverse {
    direction: rtl;
  }

  .slide-image-quote-reverse > * {
    direction: ltr;
  }

  .slide-two-panel-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .slide-failures-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  /* ========================================
     OVAL VIGNETTE
     ======================================== */

  .oval-vignette {
    mask-image: radial-gradient(ellipse 70% 65% at center, black 40%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 65% at center, black 40%, transparent 75%);
  }

  .slide-illustration {
    width: 100%;
    max-width: 450px;
    height: auto;
    border-radius: 12px;
    display: block;
    margin: 0 auto;
  }

  .slide-illustration-small {
    width: 100%;
    max-width: 280px;
    height: auto;
    border-radius: 12px;
    display: block;
    margin: 0 auto;
  }

  .slide-illustration-tiny {
    width: 100%;
    max-width: 180px;
    height: auto;
    border-radius: 12px;
    display: block;
    margin: 0 auto;
    opacity: 0.7;
  }

  .slide-image-below {
    margin-top: 1rem;
  }

  .slide-image-accent {
    position: absolute;
    bottom: 2rem;
    right: 3rem;
    opacity: 0.5;
  }

  /* ========================================
     SHIP'S WHEEL (Slide 1)
     ======================================== */

  .title-wheel {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: var(--color-accent);
    opacity: 0.12;
    z-index: 0;
  }

  .ships-wheel {
    animation: spin-slow 90s linear infinite;
  }

  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .lottie-title-glow {
    position: absolute;
    width: 500px;
    height: 400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
  }

  .slide-main-title,
  .slide-eyebrow,
  .slide-subtitle-big,
  .slide-date {
    position: relative;
    z-index: 1;
  }

  /* ========================================
     AGENT LOOP SVG (Slide 2)
     ======================================== */

  .agent-loop-svg {
    margin-top: 1rem;
  }

  .loop-circle {
    animation: spin-slow 60s linear infinite;
    transform-origin: 300px 95px;
  }

  .loop-path {
    stroke-dasharray: 120;
    stroke-dashoffset: 120;
  }

  .slide-active .loop-path-1 { animation: draw-loop 0.8s 0.5s ease forwards; }
  .slide-active .loop-path-2 { animation: draw-loop 0.8s 0.9s ease forwards; }
  .slide-active .loop-path-3 { animation: draw-loop 0.8s 1.3s ease forwards; }
  .slide-active .loop-path-4 { animation: draw-loop 0.8s 1.7s ease forwards; }

  @keyframes draw-loop {
    to { stroke-dashoffset: 0; }
  }

  .flow-arrow {
    animation: dash-flow 2s linear infinite;
  }

  @keyframes dash-flow {
    to { stroke-dashoffset: -16; }
  }

  /* ========================================
     STAT BADGES (Slide 2)
     ======================================== */

  .stat-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
    margin: 1rem 0;
  }

  .stat-badge {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    padding: 0.35rem 0.9rem;
    font-size: 0.8rem;
    font-family: var(--font-sans);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* ========================================
     TOPIC TAGS (Slide 3)
     ======================================== */

  .topic-tags-eyebrow {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 1.2rem 0 0.5rem;
    font-family: var(--font-mono);
  }

  .topic-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .topic-tag {
    background: var(--color-surface);
    border: 1px solid var(--color-pirate-teal);
    border-radius: 4px;
    padding: 0.3rem 0.7rem;
    font-size: 0.78rem;
    font-family: var(--font-sans);
    color: var(--color-pirate-teal);
  }

  /* ========================================
     LESSON CALLOUTS (Slide 9)
     ======================================== */

  .lesson-callouts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1rem;
    justify-content: center;
  }

  .lesson-callout {
    background: var(--color-surface);
    border-left: 3px solid var(--color-pirate-teal);
    border-radius: 4px;
    padding: 0.5rem 0.8rem;
    font-size: 0.8rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    flex: 1 1 200px;
    max-width: 280px;
  }

  /* ========================================
     SPECTRUM (Slide 4)
     ======================================== */

  .spectrum-container {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .spectrum-bar {
    height: 6px;
    background: var(--color-border);
    border-radius: 3px;
    position: relative;
    margin-bottom: 2rem;
    overflow: hidden;
  }

  .spectrum-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-accent), var(--color-pirate-teal));
    border-radius: 3px;
    width: 62%;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .spectrum-levels {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .spectrum-level {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 0.5rem;
    border-radius: 12px;
    cursor: pointer;
    background: transparent;
    border: 1.5px solid transparent;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: all 0.3s ease;
  }

  .spectrum-level:hover,
  .spectrum-level.active-level {
    border-color: var(--color-accent);
    background: rgba(232, 150, 62, 0.05);
    color: var(--color-text);
  }

  .spectrum-level.active-level .spectrum-icon svg {
    stroke: var(--color-accent);
  }

  .spectrum-pointer {
    font-size: 0.7rem;
    color: var(--color-accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .spectrum-level.active-level .spectrum-pointer {
    opacity: 1;
  }

  .spectrum-desc {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    min-height: 2.5em;
    transition: opacity 0.3s;
    font-style: italic;
    max-width: 500px;
    margin: 0 auto;
  }

  /* ========================================
     TWO PANELS (Slide 5)
     ======================================== */

  .two-panels {
    display: flex;
    gap: 2rem;
    align-items: stretch;
    width: 100%;
    max-width: 750px;
  }

  .panel {
    flex: 1;
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(8px);
  }

  .panel h3 {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .panel-captain h3 { color: var(--color-pirate-teal); }
  .panel-agent h3 { color: var(--color-accent); }

  .panel ul {
    list-style: none;
    padding: 0;
  }

  .panel li {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    padding: 0.35rem 0;
    padding-left: 1.2rem;
    position: relative;
  }

  .panel li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    transform: translateY(-50%);
  }

  .panel-captain li::before { background: var(--color-pirate-teal); opacity: 0.5; }
  .panel-agent li::before { background: var(--color-accent); opacity: 0.5; }

  .panel-divider {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .two-panels-stacked {
    flex-direction: column;
    gap: 0.75rem;
    max-width: 100%;
  }

  .two-panels-stacked .panel {
    padding: 1rem 1.25rem;
  }

  .two-panels-stacked .panel h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .two-panels-stacked .panel li {
    font-size: 0.85rem;
    padding: 0.2rem 0 0.2rem 1rem;
  }

  .slide-image-side-large {
    flex: 1.2;
  }

  .slide-image-side-large .slide-illustration {
    max-height: 70vh;
    object-fit: contain;
  }

  /* ========================================
     CAPABILITY CARDS (Slide 6)
     ======================================== */

  .capability-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 750px;
    width: 100%;
    margin: 1rem auto;
  }

  .cap-card {
    perspective: 600px;
    cursor: pointer;
    height: 220px;
  }

  .cap-card-front,
  .cap-card-back {
    position: absolute;
    inset: 0;
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    backface-visibility: hidden;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1.5px solid var(--color-border);
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(8px);
  }

  .cap-card {
    position: relative;
  }

  .cap-card-back {
    transform: rotateY(180deg);
    background: linear-gradient(135deg, rgba(255, 253, 247, 0.95), rgba(255, 248, 237, 0.95));
    border-color: var(--color-accent);
  }

  .cap-card.flipped .cap-card-front {
    transform: rotateY(-180deg);
  }

  .cap-card.flipped .cap-card-back {
    transform: rotateY(0);
  }

  .cap-card h3 {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    margin-top: 0.75rem;
    color: var(--color-text);
  }

  .cap-hint {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.5;
