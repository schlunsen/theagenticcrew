  document.addEventListener('keydown', (e) => {
    switch (e.key) {
      case 'ArrowRight':
      case 'ArrowDown':
      case ' ':
        e.preventDefault();
        nextSlide();
        break;
      case 'ArrowLeft':
      case 'ArrowUp':
        e.preventDefault();
        prevSlide();
        break;
      case 'n':
      case 'N':
        notesVisible = !notesVisible;
        notesPanel.classList.toggle('visible', notesVisible);
        break;
      case 'f':
      case 'F':
