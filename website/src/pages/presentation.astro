  const _origAudioToggleHandler = audioToggle.onclick;
  audioToggle.addEventListener('click', () => {
    if (!audioEnabled && bgMusicStarted) {
      // Muting — fade bg music to silence but keep it playing
      fadeBgMusicTo(0);
    } else if (audioEnabled && bgMusicStarted) {
      // Unmuting — restore bg music
      const isNarrating = currentAudio && !currentAudio.paused;
      fadeBgMusicTo(isNarrating ? BG_MUSIC_LOW : BG_MUSIC_HIGH);
