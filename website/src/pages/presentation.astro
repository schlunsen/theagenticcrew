  function applyLanguage(lang: Lang) {
    currentLang = lang;
    localStorage.setItem('presentation-lang', lang);

    // Update language selector buttons
    langBtns.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.lang === lang);
    });

    // Update all data-i18n elements
    const elements = document.querySelectorAll<HTMLElement>('[data-i18n]');
    elements.forEach(el => {
      const key = el.dataset.i18n!;
      const text = translations[lang][key];
      if (text !== undefined) {
        if (el.dataset.i18nHtml === 'true') {
          el.innerHTML = text;
        } else {
          el.innerHTML = text;
        }
      }
    });

    // Update spectrum descriptions with language-specific data attributes
    const spectrumDescEl = document.getElementById('spectrum-desc');
    if (spectrumDescEl) {
      const activeLevel = document.querySelector('.spectrum-level.active-level') as HTMLElement | null;
      if (activeLevel) {
        const descKey = lang === 'es' ? 'descEs' : 'desc';
        spectrumDescEl.textContent = (lang === 'es' && activeLevel.dataset.descEs)
          ? activeLevel.dataset.descEs
          : activeLevel.dataset.desc || '';
      }
    }

    // Update pipeline info if showing a node description
    const pipelineInfoEl = document.getElementById('pipeline-info');
    const activeNode = document.querySelector('.pipeline-node.active-node') as HTMLElement | null;
    if (pipelineInfoEl && activeNode) {
      pipelineInfoEl.textContent = (lang === 'es' && activeNode.dataset.infoEs)
        ? activeNode.dataset.infoEs
        : activeNode.dataset.info || '';
    }

    // If typing effect is or was running on the final slide, restart it with new language
    if (currentSlide === 10) {
      startTypingEffect();
    }

    // Reload audio for current slide in correct language
    reloadAudioForLanguage();
  }

  function reloadAudioForLanguage() {
    const wasPlaying = audioEnabled && currentAudio && !currentAudio.paused;

    // Fade out current audio smoothly before switching
    const fadePromise = (currentAudio && !currentAudio.paused)
      ? fadeOutAudio(currentAudio)
      : Promise.resolve();

    fadePromise.then(() => {
      // Cancel any pending audio timer
      if (pendingAudioTimer) {
        clearTimeout(pendingAudioTimer);
        pendingAudioTimer = null;
      }

      // Stop and clear all cached audio
      Object.keys(slideAudioCache).forEach(k => {
        const idx = parseInt(k);
        const audio = slideAudioCache[idx];
        if (audio) {
          audio.pause();
          audio.currentTime = 0;
          audio.src = '';
        }
        delete slideAudioCache[idx];
      });
      currentAudio = null;

      // Rebuild audio cache with language/voice-specific paths
      for (let i = 0; i < totalSlides; i++) {
        const audioUrl = getAudioUrl(i);

        const audio = new Audio();
        audio.preload = 'auto';
        audio.src = audioUrl;
        audio.volume = audioVolume;
        audio.addEventListener('error', () => {
          delete slideAudioCache[i];
        });
        audio.addEventListener('canplaythrough', () => {
          slideAudioCache[i] = audio;
        }, { once: true });
        slideAudioCache[i] = audio;
      }

      // If audio was playing, restart with new language after a smooth pause
      if (wasPlaying) {
        setTimeout(() => playSlideAudio(currentSlide), 400);
      }
    });
  }

  // Language button click handlers
  langBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.dataset.lang as Lang;
      if (lang !== currentLang) {
        applyLanguage(lang);
      }
    });
  });

  // Voice is fixed — no switcher needed

  // Apply saved language on load
  if (currentLang !== 'en') {
    applyLanguage(currentLang);
  }
</script>
