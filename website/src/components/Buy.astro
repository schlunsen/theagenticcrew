---
---

<section class="download" id="download">
  <div class="download-inner">
    <div class="download-card">
      <div class="download-book-display">
        <div class="mini-book-mock">
          <div class="mini-book-cover">
            <div class="mini-book-spine"></div>
            <div class="mini-book-front">
              <img src="/book-cover.png" alt="The Agentic Crew book cover" class="mini-cover-image" />
            </div>
          </div>
        </div>
      </div>
      <p class="download-eyebrow">Free download</p>
      <h2>Get the book</h2>
      <p class="download-subtitle">Choose your language and format</p>

      <div class="lang-tabs">
        <button class="lang-tab active" data-lang="en">English</button>
        <button class="lang-tab" data-lang="es">Español</button>
        <button class="lang-tab" data-lang="ca">Català</button>
        <button class="lang-tab" data-lang="da">Dansk</button>
      </div>

      <div class="lang-panel active" data-lang="en">
        <div class="format-grid">
          <a href="/the-agentic-crew.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>PDF</h3>
            <p>Best for desktop & tablet. Fixed layout with full formatting.</p>
          </a>
          <a href="/the-agentic-crew.epub" class="format-card" download>
            <div class="format-icon">EPUB</div>
            <h3>EPUB</h3>
            <p>Reflowable text for iPad, Kindle, Kobo & other e-readers.</p>
          </a>
        </div>
      </div>

      <div class="lang-panel" data-lang="es">
        <p class="lang-title">La Tripulación Agéntica</p>
        <div class="format-grid">
          <a href="/the-agentic-crew-es.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>PDF</h3>
            <p>Para escritorio y tableta. Diseño fijo con formato completo.</p>
          </a>
          <a href="/the-agentic-crew-es.epub" class="format-card" download>
            <div class="format-icon">EPUB</div>
            <h3>EPUB</h3>
            <p>Texto adaptable para iPad, Kindle, Kobo y otros lectores.</p>
          </a>
        </div>
      </div>

      <div class="lang-panel" data-lang="ca">
        <p class="lang-title">La Tripulació Agèntica</p>
        <div class="format-grid">
          <a href="/the-agentic-crew-ca.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>PDF</h3>
            <p>Per a escriptori i tauleta. Disseny fix amb format complet.</p>
          </a>
          <a href="/the-agentic-crew-ca.epub" class="format-card" download>
            <div class="format-icon">EPUB</div>
            <h3>EPUB</h3>
            <p>Text adaptable per a iPad, Kindle, Kobo i altres lectors.</p>
          </a>
        </div>
      </div>

      <div class="lang-panel" data-lang="da">
        <p class="lang-title">Det Agentiske Mandskab</p>
        <div class="format-grid">
          <a href="/the-agentic-crew-da.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>PDF</h3>
            <p>Bedst til desktop og tablet. Fast layout med fuld formatering.</p>
          </a>
          <a href="/the-agentic-crew-da.epub" class="format-card" download>
            <div class="format-icon">EPUB</div>
            <h3>EPUB</h3>
            <p>Flydende tekst til iPad, Kindle, Kobo og andre e-bogslæsere.</p>
          </a>
        </div>
      </div>

      <p class="download-note">All formats free. Download as many times as you like.</p>
    </div>

    <!-- Kids' Edition Card -->
    <div class="download-card kids-card">
      <div class="download-book-display">
        <div class="mini-book-mock">
          <div class="mini-book-cover kids-book-cover">
            <div class="mini-book-spine kids-spine"></div>
            <div class="mini-book-front">
              <img src="/book-cover-kids.jpg" alt="The Agentic Crew Kids' Edition cover" class="mini-cover-image" />
            </div>
          </div>
        </div>
      </div>
      <p class="download-eyebrow">For young captains (ages 9+)</p>
      <h2>Kids' Edition</h2>
      <p class="download-subtitle">The same ideas, told through ships, robots &amp; exploding sandwiches</p>

      <div class="lang-tabs kids-tabs">
        <button class="lang-tab-kids active" data-lang-kids="en">English</button>
        <button class="lang-tab-kids" data-lang-kids="es">Español</button>
        <button class="lang-tab-kids" data-lang-kids="ca">Català</button>
        <button class="lang-tab-kids" data-lang-kids="da">Dansk</button>
      </div>

      <div class="lang-panel-kids active" data-lang-kids="en">
        <div class="format-grid">
          <a href="/the-agentic-crew-kids.pdf" class="format-card kids-format" download>
            <div class="format-icon kids-icon">PDF</div>
            <h3>PDF</h3>
            <p>Illustrated A5 book. Best for reading together or printing.</p>
          </a>
        </div>
      </div>

      <div class="lang-panel-kids" data-lang-kids="es">
        <p class="lang-title">La Tripulación Agéntica — Guía para Niños</p>
        <div class="format-grid">
          <a href="/the-agentic-crew-kids-es.pdf" class="format-card kids-format" download>
            <div class="format-icon kids-icon">PDF</div>
            <h3>PDF</h3>
            <p>Libro ilustrado A5. Ideal para leer juntos o imprimir.</p>
          </a>
        </div>
      </div>

      <div class="lang-panel-kids" data-lang-kids="ca">
        <p class="lang-title">La Tripulació Agèntica — Guia per a Nens</p>
        <div class="format-grid">
          <a href="/the-agentic-crew-kids-ca.pdf" class="format-card kids-format" download>
            <div class="format-icon kids-icon">PDF</div>
            <h3>PDF</h3>
            <p>Llibre il·lustrat A5. Ideal per llegir junts o imprimir.</p>
          </a>
        </div>
      </div>

      <div class="lang-panel-kids" data-lang-kids="da">
        <p class="lang-title">Det Agentiske Mandskab — Børneguide</p>
        <div class="format-grid">
          <a href="/the-agentic-crew-kids-da.pdf" class="format-card kids-format" download>
            <div class="format-icon kids-icon">PDF</div>
            <h3>PDF</h3>
            <p>Illustreret A5-bog. Bedst til at læse sammen eller printe.</p>
          </a>
        </div>
      </div>

      <p class="download-note">Fully illustrated with AI-generated artwork. Same content, kid-friendly language.</p>
    </div>

    <!-- Support Section -->
    <div class="download-card support-card">
      <div class="support">
        <div class="support-divider"></div>
        <p class="support-text">Enjoyed the book? This project is free and always will be.</p>
        <a href="https://buymeacoffee.com/schlunsen" target="_blank" rel="noopener" class="btn-coffee">
          <span class="coffee-icon">&#9749;</span> Buy me a coffee
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Adult book tabs
    const tabs = document.querySelectorAll('.lang-tab');
    const panels = document.querySelectorAll('.lang-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const lang = tab.getAttribute('data-lang');
        tabs.forEach(t => t.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.querySelector(`.lang-panel[data-lang="${lang}"]`)?.classList.add('active');
      });
    });

    // Kids book tabs
    const kidsTabs = document.querySelectorAll('.lang-tab-kids');
    const kidsPanels = document.querySelectorAll('.lang-panel-kids');

    kidsTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const lang = tab.getAttribute('data-lang-kids');
        kidsTabs.forEach(t => t.classList.remove('active'));
        kidsPanels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.querySelector(`.lang-panel-kids[data-lang-kids="${lang}"]`)?.classList.add('active');
      });
    });
  });
</script>

<style>
  .download {
    padding: 6rem 2rem;
    position: relative;
  }

  .download::before {
    content: '';
    position: absolute;
    top: 30%;
    left: 50%;
    width: 60%;
    height: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(245, 166, 35, 0.06), transparent 70%);
    pointer-events: none;
  }

  .download-inner {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
  }

  .download-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 3rem;
    text-align: center;
    transition: border-color 0.3s, box-shadow 0.3s;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
  }

  .download-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 40px rgba(232, 150, 62, 0.12);
  }

  .download-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .download-subtitle {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }

  .lang-tabs {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .lang-tab {
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .lang-tab:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .lang-tab.active {
    background: rgba(232, 150, 62, 0.1);
    border-color: var(--color-accent);
    color: var(--color-accent-deep);
    font-weight: 600;
  }

  .lang-panel {
    display: none;
  }

  .lang-panel.active {
    display: block;
  }

  .lang-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .format-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .format-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 2rem 1.5rem;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .format-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(232, 150, 62, 0.1);
    color: inherit;
  }

  .format-icon {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent-deep);
    background: rgba(232, 150, 62, 0.1);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    letter-spacing: 0.05em;
  }

  .format-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .format-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .download-note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .support {
    margin-top: 2.5rem;
  }

  .support-divider {
    width: 60px;
    height: 1px;
    background: var(--color-border);
    margin: 0 auto 1.5rem;
  }

  .support-text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .btn-coffee {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2.25rem;
    border-radius: 12px;
    border: none;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-deep));
    color: #fff;
    font-weight: 700;
    font-size: 1.1rem;
    font-family: inherit;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(232, 150, 62, 0.25);
    text-decoration: none;
  }

  .btn-coffee:hover {
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent));
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(232, 150, 62, 0.35);
  }

  .coffee-icon {
    font-size: 1.25rem;
  }

  /* 3D Book mockup in download cards */
  .download-book-display {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .mini-book-mock {
    perspective: 600px;
  }

  .mini-book-cover {
    width: 160px;
    height: 228px;
    position: relative;
    transform: rotateY(-15deg) rotateX(3deg);
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    filter: drop-shadow(0 12px 24px rgba(0, 0, 0, 0.12));
  }

  .mini-book-cover:hover {
    transform: rotateY(-5deg) rotateX(1deg) scale(1.03);
    filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.18));
  }

  .mini-book-front {
    width: 100%;
    height: 100%;
    border-radius: 3px 8px 8px 3px;
    overflow: hidden;
    box-shadow:
      6px 6px 20px rgba(0, 0, 0, 0.12),
      0 0 40px rgba(245, 166, 35, 0.08),
      inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    position: relative;
  }

  .mini-book-front::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.18) 0%,
      transparent 40%,
      transparent 60%,
      rgba(255, 255, 255, 0.05) 100%
    );
    pointer-events: none;
    z-index: 1;
    border-radius: inherit;
  }

  .mini-cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mini-book-spine {
    position: absolute;
    left: -14px;
    top: 0;
    width: 14px;
    height: 100%;
    background: linear-gradient(to right, #c97b1e, #e8963e);
    transform: rotateY(90deg);
    transform-origin: right;
    border-radius: 3px 0 0 3px;
  }

  .kids-spine {
    background: linear-gradient(to right, #1a8a9e, #2e9bb7);
  }

  .kids-book-cover {
    filter: drop-shadow(0 12px 24px rgba(46, 155, 183, 0.15));
  }

  .kids-book-cover:hover {
    filter: drop-shadow(0 16px 32px rgba(46, 155, 183, 0.22));
  }

  /* Kids' Edition styles */
  .kids-card {
    margin-top: 2rem;
    border-color: rgba(46, 155, 183, 0.3);
    background: linear-gradient(135deg, #ffffff, rgba(46, 155, 183, 0.04));
  }

  .kids-card:hover {
    border-color: var(--color-pirate-teal);
  }

  .kids-card .download-eyebrow {
    color: var(--color-pirate-teal);
  }

  .lang-tab-kids {
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .lang-tab-kids:hover {
    border-color: var(--color-pirate-teal);
    color: var(--color-text);
  }

  .lang-tab-kids.active {
    background: rgba(46, 155, 183, 0.1);
    border-color: var(--color-pirate-teal);
    color: var(--color-pirate-teal);
    font-weight: 600;
  }

  .lang-panel-kids {
    display: none;
  }

  .lang-panel-kids.active {
    display: block;
  }

  .kids-icon {
    color: var(--color-pirate-teal) !important;
    background: rgba(46, 155, 183, 0.1) !important;
  }

  .kids-format:hover {
    border-color: var(--color-pirate-teal) !important;
    box-shadow: 0 8px 30px rgba(46, 155, 183, 0.1) !important;
  }

  .support-card {
    margin-top: 2rem;
    border: none;
    background: transparent;
    box-shadow: none;
  }

  @media (max-width: 480px) {
    .format-grid {
      grid-template-columns: 1fr;
    }

    .download-card {
      padding: 2rem 1.5rem;
    }

    .lang-tabs {
      flex-wrap: wrap;
    }
  }
</style>
