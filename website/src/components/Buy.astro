---
---

<section class="download" id="download">
  <div class="download-inner">
    <div class="download-card">
      <p class="download-eyebrow">Free download</p>
      <h2>Get the book</h2>
      <p class="download-subtitle">Choose the format that works best for you</p>
      <div class="format-grid">
        <a href="/the-agentic-crew.pdf" class="format-card" download>
          <div class="format-icon">PDF</div>
          <h3>PDF</h3>
          <p>Best for desktop & tablet. Fixed layout with full formatting.</p>
        </a>
        <a href="/the-agentic-crew.epub" class="format-card" download>
          <div class="format-icon">EPUB</div>
          <h3>EPUB</h3>
          <p>Reflowable text for iPad, Kindle, Kobo & other e-readers.</p>
        </a>
      </div>
      <p class="download-note">Both formats included. Download as many times as you like.</p>

      <div class="support">
        <div class="support-divider"></div>
        <p class="support-text">Enjoyed the book? This project is free and always will be.</p>
        <a href="https://buymeacoffee.com/schlunsen" target="_blank" rel="noopener" class="btn-coffee">
          <span class="coffee-icon">&#9749;</span> Buy me a coffee
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .download {
    padding: 6rem 2rem;
    position: relative;
  }

  .download::before {
    content: '';
    position: absolute;
    top: 30%;
    left: 50%;
    width: 60%;
    height: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, var(--color-accent-glow), transparent 70%);
    pointer-events: none;
  }

  .download-inner {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
  }

  .download-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 3rem;
    text-align: center;
    transition: border-color 0.3s;
  }

  .download-card:hover {
    border-color: var(--color-accent);
  }

  .download-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-light);
    margin-bottom: 0.75rem;
  }

  h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .download-subtitle {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 2.5rem;
  }

  .format-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .format-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 2rem 1.5rem;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .format-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 0 30px var(--color-accent-glow);
    color: inherit;
  }

  .format-icon {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent-light);
    background: var(--color-accent-glow);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    letter-spacing: 0.05em;
  }

  .format-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .format-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .download-note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .support {
    margin-top: 2.5rem;
  }

  .support-divider {
    width: 60px;
    height: 1px;
    background: var(--color-border);
    margin: 0 auto 1.5rem;
  }

  .support-text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .btn-coffee {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9rem 2.25rem;
    border-radius: 12px;
    border: none;
    background: linear-gradient(135deg, #d4a754, #e8c373);
    color: #0a0e1a;
    font-weight: 700;
    font-size: 1.1rem;
    font-family: inherit;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 30px rgba(212, 167, 84, 0.2);
    text-decoration: none;
  }

  .btn-coffee:hover {
    background: linear-gradient(135deg, #e8c373, #f0d48a);
    color: #0a0e1a;
    transform: translateY(-2px);
    box-shadow: 0 0 50px rgba(212, 167, 84, 0.35);
  }

  .coffee-icon {
    font-size: 1.25rem;
  }

  @media (max-width: 480px) {
    .format-grid {
      grid-template-columns: 1fr;
    }

    .download-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
