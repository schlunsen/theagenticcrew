---
---

<section class="download" id="download">
  <div class="download-inner">
    <div class="download-card">
      <div class="download-book-display">
        <div class="mini-book-mock">
          <div class="mini-book-cover">
            <div class="mini-book-spine"></div>
            <div class="mini-book-front">
              <img src="/book-cover.png" alt="The Agentic Crew book cover" class="mini-cover-image" />
            </div>
          </div>
        </div>
      </div>
      <p class="download-eyebrow">Free download</p>
      <h2>Get the book</h2>
      <p class="download-subtitle">Choose your language and format</p>

      <div class="lang-tabs">
        <button class="lang-tab active" data-lang="en">English</button>
        <button class="lang-tab" data-lang="es">Español</button>
        <button class="lang-tab" data-lang="ca">Català</button>
        <button class="lang-tab" data-lang="da">Dansk</button>
      </div>

      <div class="lang-panel active" data-lang="en">
        <div class="format-grid">
          <a href="/the-agentic-crew.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>PDF</h3>
            <p>Best for desktop & tablet. Fixed layout with full formatting.</p>
          </a>
          <a href="/the-agentic-crew.epub" class="format-card" download>
            <div class="format-icon">EPUB</div>
            <h3>EPUB</h3>
            <p>Reflowable text for iPad, Kindle, Kobo & other e-readers.</p>
          </a>
        </div>
      </div>

      <div class="lang-panel" data-lang="es">
        <p class="lang-title">La Tripulación Agéntica</p>
        <div class="format-grid">
          <a href="/the-agentic-crew-es.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>PDF</h3>
            <p>Para escritorio y tableta. Diseño fijo con formato completo.</p>
          </a>
          <a href="/the-agentic-crew-es.epub" class="format-card" download>
            <div class="format-icon">EPUB</div>
            <h3>EPUB</h3>
            <p>Texto adaptable para iPad, Kindle, Kobo y otros lectores.</p>
          </a>
        </div>
      </div>

      <div class="lang-panel" data-lang="ca">
        <p class="lang-title">La Tripulació Agèntica</p>
        <div class="format-grid">
          <a href="/the-agentic-crew-ca.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>PDF</h3>
            <p>Per a escriptori i tauleta. Disseny fix amb format complet.</p>
          </a>
          <a href="/the-agentic-crew-ca.epub" class="format-card" download>
            <div class="format-icon">EPUB</div>
            <h3>EPUB</h3>
            <p>Text adaptable per a iPad, Kindle, Kobo i altres lectors.</p>
          </a>
        </div>
      </div>

      <div class="lang-panel" data-lang="da">
        <p class="lang-title">Det Agentiske Mandskab</p>
        <div class="format-grid">
          <a href="/the-agentic-crew-da.pdf" class="format-card" download>
            <div class="format-icon">PDF</div>
            <h3>PDF</h3>
            <p>Bedst til desktop og tablet. Fast layout med fuld formatering.</p>
          </a>
          <a href="/the-agentic-crew-da.epub" class="format-card" download>
            <div class="format-icon">EPUB</div>
            <h3>EPUB</h3>
            <p>Flydende tekst til iPad, Kindle, Kobo og andre e-bogslæsere.</p>
          </a>
        </div>
      </div>

      <a href="/presentation" class="presentation-link">
        <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <rect x="2" y="3" width="16" height="12" rx="2" />
          <path d="M8 9l4-2.5v5L8 9z" fill="currentColor" opacity="0.6" />
          <line x1="6" y1="18" x2="14" y2="18" />
        </svg>
        Interactive Presentation
      </a>
      <p class="download-note">All formats free. Download as many times as you like.</p>
    </div>

    <!-- More from the series -->
    <div class="series-sidebar">
      <p class="series-label">More from the series</p>

      <a href="/books/crew-guide" class="ref-card crew-ref">
        <div class="ref-cover">
          <img src="/book-cover-crew.png" alt="Crew Member's Guide cover" />
        </div>
        <div class="ref-body">
          <span class="ref-badge crew-badge">For the whole crew</span>
          <h3>Crew Member's Guide</h3>
          <p>Tech-savvy but don't code? Same ideas as the engineering book, translated for non-programmers.</p>
          <span class="ref-cta crew-cta">Learn more &rarr;</span>
        </div>
      </a>

      <a href="/books/hands-on" class="ref-card hands-on-ref">
        <div class="ref-cover">
          <div class="hands-on-cover-placeholder">
            <span class="hands-on-cover-eyebrow">LEARN BY DOING</span>
            <span class="hands-on-cover-title">The Agentic Crew</span>
            <span class="hands-on-cover-subtitle">Hands-On Guide</span>
          </div>
        </div>
        <div class="ref-body">
          <span class="ref-badge hands-on-badge">Practical exercises</span>
          <h3>Hands-On Guide</h3>
          <p>Set up your machine, fork a repo, submit a PR. The lab companion to the engineering and crew books.</p>
          <span class="ref-cta hands-on-cta">Learn more &rarr;</span>
        </div>
      </a>

      <div class="support">
        <div class="support-divider"></div>
        <p class="support-text">Enjoyed the book? This project is free and always will be.</p>
        <a href="https://buymeacoffee.com/schlunsen" target="_blank" rel="noopener" class="btn-coffee">
          <span class="coffee-icon">&#9749;</span> Buy me a coffee
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.lang-tab');
    const panels = document.querySelectorAll('.lang-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const lang = tab.getAttribute('data-lang');
        tabs.forEach(t => t.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.querySelector(`.lang-panel[data-lang="${lang}"]`)?.classList.add('active');
      });
    });
  });
</script>

<style>
  .download {
    padding: 6rem 2rem;
    position: relative;
  }

  .download::before {
    content: '';
    position: absolute;
    top: 30%;
    left: 50%;
    width: 60%;
    height: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(245, 166, 35, 0.06), transparent 70%);
    pointer-events: none;
  }

  .download-inner {
    max-width: 960px;
    margin: 0 auto;
    position: relative;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Main download card ── */
  .download-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: border-color 0.3s, box-shadow 0.3s;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
  }

  .download-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 40px rgba(232, 150, 62, 0.12);
  }

  .download-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .download-subtitle {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }

  .lang-tabs {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .lang-tab {
    padding: 0.4rem 0.9rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    font-family: inherit;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .lang-tab:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .lang-tab.active {
    background: rgba(232, 150, 62, 0.1);
    border-color: var(--color-accent);
    color: var(--color-accent-deep);
    font-weight: 600;
  }

  .lang-panel { display: none; }
  .lang-panel.active { display: block; }

  .lang-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .format-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .format-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.25rem 1rem;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .format-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(232, 150, 62, 0.1);
    color: inherit;
  }

  .format-icon {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent-deep);
    background: rgba(232, 150, 62, 0.1);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    letter-spacing: 0.05em;
  }

  .format-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .format-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .download-note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .presentation-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    border: 1px solid rgba(232, 150, 62, 0.2);
    background: rgba(232, 150, 62, 0.04);
    transition: all 0.25s ease;
    margin-bottom: 0.75rem;
  }

  .presentation-link:hover {
    background: rgba(232, 150, 62, 0.1);
    border-color: rgba(232, 150, 62, 0.4);
    transform: translateY(-1px);
  }

  /* ── 3D Book mockup ── */
  .download-book-display {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .mini-book-mock { perspective: 600px; }

  .mini-book-cover {
    width: 160px;
    height: 228px;
    position: relative;
    transform: rotateY(-15deg) rotateX(3deg);
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    filter: drop-shadow(0 12px 24px rgba(0, 0, 0, 0.12));
  }

  .mini-book-cover:hover {
    transform: rotateY(-5deg) rotateX(1deg) scale(1.03);
    filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.18));
  }

  .mini-book-front {
    width: 100%;
    height: 100%;
    border-radius: 3px 8px 8px 3px;
    overflow: hidden;
    box-shadow:
      6px 6px 20px rgba(0, 0, 0, 0.12),
      0 0 40px rgba(245, 166, 35, 0.08),
      inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    position: relative;
  }

  .mini-book-front::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, transparent 40%, transparent 60%, rgba(255,255,255,0.05) 100%);
    pointer-events: none;
    z-index: 1;
    border-radius: inherit;
  }

  .mini-cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mini-book-spine {
    position: absolute;
    left: -14px;
    top: 0;
    width: 14px;
    height: 100%;
    background: linear-gradient(to right, #c97b1e, #e8963e);
    transform: rotateY(90deg);
    transform-origin: right;
    border-radius: 3px 0 0 3px;
  }

  /* ── Series sidebar ── */
  .series-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .series-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  /* ── Reference cards ── */
  .ref-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background: var(--color-bg-card);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.25s;
  }

  .ref-card:hover {
    transform: translateY(-2px);
    color: inherit;
  }

  .crew-ref:hover {
    border-color: rgb(201, 168, 76);
    box-shadow: 0 6px 28px rgba(201, 168, 76, 0.12);
  }

  .hands-on-ref:hover {
    border-color: rgb(80, 160, 100);
    box-shadow: 0 6px 28px rgba(80, 160, 100, 0.12);
  }

  .ref-cover {
    width: 80px;
    min-width: 80px;
    height: 110px;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 2px 4px 12px rgba(0, 0, 0, 0.1);
    flex-shrink: 0;
  }

  .ref-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ref-body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .ref-badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .crew-badge { color: rgb(180, 140, 50); }
  .hands-on-badge { color: rgb(60, 140, 80); }

  .ref-body h3 {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .ref-body p {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .ref-cta {
    font-size: 0.82rem;
    font-weight: 600;
    margin-top: auto;
    transition: gap 0.2s;
  }

  .crew-cta { color: rgb(180, 140, 50); }
  .hands-on-cta { color: rgb(60, 140, 80); }

  .ref-card:hover .ref-cta { text-decoration: underline; }

  /* Hands-on placeholder cover */
  .hands-on-cover-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #0a0e1a, #1a2040);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 0.5rem;
    gap: 0.3rem;
  }

  .hands-on-cover-eyebrow {
    font-size: 0.3rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: rgb(100, 200, 130);
  }

  .hands-on-cover-title {
    font-family: var(--font-serif);
    font-size: 0.65rem;
    font-weight: 700;
    color: #f0ead6;
    text-align: center;
    line-height: 1.2;
  }

  .hands-on-cover-subtitle {
    font-size: 0.4rem;
    font-style: italic;
    color: rgba(100, 200, 130, 0.8);
  }

  /* ── Support section ── */
  .support {
    text-align: center;
    margin-top: 1rem;
  }

  .support-divider {
    width: 60px;
    height: 1px;
    background: var(--color-border);
    margin: 0 auto 1.5rem;
  }

  .support-text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .btn-coffee {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 12px;
    border: none;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-deep));
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    font-family: inherit;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(232, 150, 62, 0.25);
    text-decoration: none;
  }

  .btn-coffee:hover {
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent));
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(232, 150, 62, 0.35);
  }

  .coffee-icon { font-size: 1.15rem; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .download-inner {
      grid-template-columns: 1fr;
      max-width: 540px;
    }

    .download-card {
      padding: 3rem;
    }

    .format-card {
      padding: 2rem 1.5rem;
      gap: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .format-grid {
      grid-template-columns: 1fr;
    }

    .download-card {
      padding: 2rem 1.5rem;
    }

    .ref-card {
      padding: 1rem;
      gap: 1rem;
    }

    .ref-cover {
      width: 64px;
      min-width: 64px;
      height: 88px;
    }
  }
</style>
