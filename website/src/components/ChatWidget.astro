---
// ChatWidget.astro — Parrot AI chatbot powered by fine-tuned Polly model via Transformers.js (WebGPU)
// Runs entirely in the user's browser, no server needed
---

<!-- Floating chat widget -->
<div id="chat-widget">
  <!-- Floating parrot button -->
  <button id="chat-toggle" aria-label="Open AI chat assistant">
    <img src="/parrot-avatar.png" alt="Parrot AI Assistant" />
    <span class="chat-badge">AI</span>
  </button>

  <!-- Chat panel -->
  <div id="chat-panel" class="chat-hidden">
    <!-- Header -->
    <div class="chat-header">
      <div class="chat-header-left">
        <img src="/parrot-avatar.png" alt="Polly" class="chat-header-avatar" />
        <div>
          <span class="chat-header-name">Polly</span>
          <span class="chat-header-status" id="chat-status">●&nbsp;Ready to load</span>
        </div>
      </div>
      <button id="chat-close" aria-label="Close chat">&times;</button>
    </div>

    <!-- Loading screen (shown before model is ready) -->
    <div id="chat-loader" class="chat-loader">
      <div class="loader-content">
        <img src="/parrot-avatar.png" alt="Polly" class="loader-avatar" />
        <h3>Meet Polly 🦜</h3>
        <p class="loader-desc">Your AI guide to <em>The Agentic Crew</em>.<br/>Runs entirely in your browser — private & offline-capable.</p>
        <p class="loader-disclaimer">⚠️ Polly is a <strong>very small model</strong> (0.5B) and may hallucinate. She's trained on the book but take answers with a grain of salt!</p>

        <div id="loader-init" class="loader-init">
          <button id="chat-load-btn" class="loader-btn">
            <span class="loader-btn-icon">⚡</span>
            Load AI Model
          </button>
          <p class="loader-note">~500 MB download · cached for future visits</p>
          <p class="loader-req">Runs in any modern browser</p>
          <a href="/polly" class="loader-link">How Polly was built →</a>
        </div>

        <div id="loader-progress" class="loader-progress" style="display:none;">
          <div class="progress-bar-track">
            <div class="progress-bar-fill" id="progress-fill"></div>
          </div>
          <p class="progress-text" id="progress-text">Initializing...</p>
          <div class="progress-details" id="progress-details"></div>
        </div>
      </div>
    </div>

    <!-- Messages area -->
    <div id="chat-messages" class="chat-messages" style="display:none;">
      <div class="chat-welcome">
        <p>🦜 <strong>Ahoy!</strong> I'm Polly, your guide to <em>The Agentic Crew</em>. Ask me anything about the book!</p>
        <p class="chat-welcome-disclaimer">I'm a tiny 0.5B model running in your browser — I can hallucinate, so don't take my word as gospel! Learn more about how I was built on the <a href="/polly">/polly</a> page.</p>
      </div>
    </div>

    <!-- Input area -->
    <div class="chat-input-area" id="chat-input-area" style="display:none;">
      <textarea id="chat-input" placeholder="Ask about the book..." rows="1" autocomplete="off"></textarea>
      <button id="chat-send" aria-label="Send message" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  /* ── Chat Widget Styles ── */
  #chat-widget {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9990;
    font-family: var(--font-sans, 'Inter', system-ui, sans-serif);
  }

  /* ── Toggle Button ── */
  #chat-toggle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 3px solid var(--color-accent, #e8963e);
    background: var(--color-bg-card, #ffffff);
    cursor: pointer;
    box-shadow:
      0 4px 20px rgba(0,0,0,0.25),
      0 0 0 3px rgba(232, 150, 62, 0.9),
      0 0 12px 4px rgba(232, 150, 62, 0.55),
      0 0 28px 8px rgba(232, 150, 62, 0.2),
      0 0 48px 14px rgba(56, 160, 220, 0.12);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    padding: 0;
    overflow: hidden;
    animation: pulse-ring 2.8s ease-in-out infinite;
  }

  #chat-toggle:hover {
    transform: scale(1.1);
    box-shadow:
      0 6px 28px rgba(0,0,0,0.3),
      0 0 0 3px rgba(232, 150, 62, 1),
      0 0 20px 8px rgba(232, 150, 62, 0.7),
      0 0 40px 14px rgba(232, 150, 62, 0.35),
      0 0 60px 20px rgba(56, 160, 220, 0.2);
    animation: none;
  }

  #chat-toggle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
  }

  .chat-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    background: var(--color-accent, #e8963e);
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 8px;
    letter-spacing: 0.5px;
  }

  @keyframes pulse-ring {
    0%, 100% {
      box-shadow:
        0 4px 20px rgba(0,0,0,0.25),
        0 0 0 3px rgba(232, 150, 62, 0.9),
        0 0 12px 4px rgba(232, 150, 62, 0.55),
        0 0 28px 8px rgba(232, 150, 62, 0.2),
        0 0 48px 14px rgba(56, 160, 220, 0.12);
    }
    50% {
      box-shadow:
        0 4px 20px rgba(0,0,0,0.25),
        0 0 0 5px rgba(232, 150, 62, 0.7),
        0 0 18px 8px rgba(232, 150, 62, 0.45),
        0 0 38px 14px rgba(232, 150, 62, 0.18),
        0 0 65px 22px rgba(56, 160, 220, 0.18);
    }
  }

  /* ── Chat Panel ── */
  #chat-panel {
    position: absolute;
    bottom: 80px;
    right: 0;
    width: 400px;
    max-width: calc(100vw - 32px);
    height: 560px;
    max-height: calc(100vh - 120px);
    background: var(--color-bg-card, #ffffff);
    border-radius: 16px;
    box-shadow: 0 12px 48px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  #chat-panel.chat-hidden {
    opacity: 0;
    transform: translateY(16px) scale(0.95);
    pointer-events: none;
  }

  /* ── Header ── */
  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    background: linear-gradient(135deg, #2a1f14 0%, #3d2e1f 100%);
    color: white;
    flex-shrink: 0;
  }

  .chat-header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .chat-header-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid var(--color-accent, #e8963e);
  }

  .chat-header-name {
    font-weight: 600;
    font-size: 15px;
    display: block;
    line-height: 1.2;
  }

  .chat-header-status {
    font-size: 11px;
    opacity: 0.7;
    display: block;
  }

  #chat-close {
    background: none;
    border: none;
    color: white;
    font-size: 24px;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s;
    padding: 0 4px;
    line-height: 1;
  }

  #chat-close:hover { opacity: 1; }

  /* ── Loading Screen ── */
  .chat-loader {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 24px;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg-elevated, #fff8ed) 0%, var(--color-bg, #fffdf7) 100%);
  }

  .loader-content {
    max-width: 300px;
  }

  .loader-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 3px solid var(--color-accent, #e8963e);
    margin: 0 auto 16px;
    animation: gentle-bob 3s ease-in-out infinite;
  }

  @keyframes gentle-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .loader-content h3 {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-text, #2a1f14);
    margin-bottom: 8px;
  }

  .loader-desc {
    font-size: 13px;
    color: var(--color-text-muted, #6b5e50);
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .loader-disclaimer {
    font-size: 11.5px;
    color: var(--color-text-muted, #6b5e50);
    line-height: 1.45;
    margin-bottom: 20px;
    padding: 8px 12px;
    background: rgba(232, 150, 62, 0.08);
    border-left: 3px solid var(--color-accent, #e8963e);
    border-radius: 4px;
    text-align: left;
  }

  .loader-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    background: linear-gradient(135deg, var(--color-accent, #e8963e), var(--color-accent-deep, #c97b1e));
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 14px rgba(232, 150, 62, 0.35);
  }

  .loader-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(232, 150, 62, 0.45);
  }

  .loader-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .loader-btn-icon { font-size: 18px; }

  .loader-note {
    font-size: 12px;
    color: var(--color-text-muted, #6b5e50);
    margin-top: 12px;
  }

  .loader-req {
    font-size: 11px;
    color: var(--color-text-muted, #6b5e50);
    opacity: 0.6;
    margin-top: 4px;
  }

  .loader-link {
    display: inline-block;
    margin-top: 10px;
    font-size: 12px;
    color: var(--color-pirate-teal, #2e9bb7);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .loader-link:hover {
    opacity: 1;
    text-decoration: underline;
  }

  /* ── Progress Bar ── */
  .loader-progress {
    margin-top: 8px;
  }

  .progress-bar-track {
    width: 100%;
    height: 8px;
    background: var(--color-border, #ecdfc8);
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-accent, #e8963e), var(--color-pirate-teal, #2e9bb7));
    border-radius: 4px;
    transition: width 0.3s ease;
  }

  .progress-text {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text, #2a1f14);
    margin-top: 12px;
  }

  .progress-details {
    font-size: 11px;
    color: var(--color-text-muted, #6b5e50);
    margin-top: 4px;
    min-height: 16px;
  }

  /* ── Messages ── */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: linear-gradient(180deg, var(--color-bg-elevated, #fff8ed) 0%, var(--color-bg, #fffdf7) 100%);
  }

  .chat-welcome {
    background: var(--color-accent-glow, rgba(245, 166, 35, 0.12));
    border: 1px solid var(--color-border-light, #f0e6d4);
    border-radius: 12px;
    padding: 14px 16px;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--color-text, #2a1f14);
  }

  .chat-welcome-disclaimer {
    margin-top: 10px;
    font-size: 11.5px;
    color: var(--color-text-muted, #6b5e50);
    line-height: 1.45;
    padding-top: 10px;
    border-top: 1px solid var(--color-border-light, #f0e6d4);
  }

  .chat-welcome-disclaimer a {
    color: var(--color-accent, #e8963e);
    font-weight: 600;
    text-decoration: none;
  }

  .chat-welcome-disclaimer a:hover {
    text-decoration: underline;
  }

  .chat-msg {
    display: flex;
    gap: 10px;
    max-width: 92%;
    animation: msg-in 0.3s ease-out;
  }

  @keyframes msg-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .chat-msg.user {
    align-self: flex-end;
    flex-direction: row-reverse;
  }

  .chat-msg-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .chat-msg-bubble {
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 13.5px;
    line-height: 1.55;
    word-break: break-word;
  }

  .chat-msg.assistant .chat-msg-bubble {
    background: var(--color-bg-card, #ffffff);
    border: 1px solid var(--color-border-light, #f0e6d4);
    color: var(--color-text, #2a1f14);
    border-bottom-left-radius: 4px;
  }

  .chat-msg.user .chat-msg-bubble {
    background: linear-gradient(135deg, var(--color-accent, #e8963e), var(--color-accent-deep, #c97b1e));
    color: white;
    border-bottom-right-radius: 4px;
  }

  .chat-msg-bubble .thinking-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-pirate-teal, #2e9bb7);
    margin-bottom: 4px;
  }

  /* Typing indicator */
  .typing-dots {
    display: inline-flex;
    gap: 4px;
    padding: 4px 0;
  }

  .typing-dots span {
    width: 6px;
    height: 6px;
    background: var(--color-text-muted, #6b5e50);
    border-radius: 50%;
    animation: typing-bounce 1.4s ease-in-out infinite;
  }

  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typing-bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-6px); opacity: 1; }
  }

  /* ── Input Area ── */
  .chat-input-area {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--color-border-light, #f0e6d4);
    background: var(--color-bg-card, #ffffff);
    flex-shrink: 0;
  }

  #chat-input {
    flex: 1;
    border: 1px solid var(--color-border, #ecdfc8);
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 13.5px;
    font-family: inherit;
    resize: none;
    max-height: 100px;
    line-height: 1.4;
    background: var(--color-bg, #fffdf7);
    color: var(--color-text, #2a1f14);
    outline: none;
    transition: border-color 0.2s;
  }

  /* Constrain any images inside message bubbles to sensible sizes */
  .chat-msg-bubble img {
    max-width: 100%;
    max-height: 200px;
    border-radius: 8px;
    margin: 6px 0;
  }

  #chat-input:focus {
    border-color: var(--color-accent, #e8963e);
  }

  #chat-input::placeholder {
    color: var(--color-text-muted, #6b5e50);
    opacity: 0.6;
  }

  #chat-send {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    border: none;
    background: linear-gradient(135deg, var(--color-accent, #e8963e), var(--color-accent-deep, #c97b1e));
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: opacity 0.2s, transform 0.2s;
  }

  #chat-send:hover:not(:disabled) { transform: scale(1.05); }
  #chat-send:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ── Performance Stats ── */
  .chat-stats {
    font-size: 10px;
    color: var(--color-text-muted, #6b5e50);
    opacity: 0.6;
    text-align: right;
    padding: 2px 4px 0;
  }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    #chat-widget { bottom: 16px; right: 16px; }
    #chat-toggle { width: 56px; height: 56px; }

    #chat-panel {
      width: calc(100vw - 24px);
      height: calc(100vh - 100px);
      bottom: 72px;
      right: -8px;
      border-radius: 12px;
    }
  }

  /* ── WebGPU not supported ── */
  .loader-unsupported {
    padding: 20px;
    text-align: center;
  }

  .loader-unsupported p {
    font-size: 13px;
    color: var(--color-pirate-red, #d94f4f);
    margin-bottom: 8px;
  }

  .loader-unsupported a {
    color: var(--color-pirate-teal, #2e9bb7);
    text-decoration: underline;
  }
</style>

<script>
  // ── Chat Widget Controller ──
  (function() {
    const TRANSFORMERS_URL = 'https://cdn.jsdelivr.net/npm/@huggingface/transformers@3.6.0';
    let TextStreamerClass = null; // will be set during model loading
    const MODEL_ID = 'kamante/polly-qwen25-0.5b-ONNX';
    const MODEL_LABEL = 'Polly-0.5B';
    const CHUNKS_URL = '/book-chunks.json';
    const TOP_K = 5; // number of chunks to retrieve per query

    // Base system prompt (book context gets injected dynamically via RAG)
    const SYSTEM_PROMPT_BASE = `You are Polly, a friendly and knowledgeable AI parrot assistant for "The Agentic Crew" — a free set of books by Rasmus Schlünsen about building with AI agents.

There are three books:
1. "The Agentic Crew — Engineering Guide" (18 chapters: Introduction, Context, What Is An Agent, Guardrails, Git, Sandboxes, Testing As The Feedback Loop, Convention Over Configuration, Tool Integrations, Local Vs Commercial LLMs, Prompting As Engineering, Multi Agent Orchestration, CI/CD And Agents, War Stories, Agents As Pentesters, When Not To Use Agents, Agentic Teams, Final Words)
2. "The Agentic Crew — Crew Member's Guide" (19 chapters, for non-programmers)
3. "The Agentic Crew — Hands-On Guide" (3 chapters: Setting Up Your Workstation, Your First Pull Request, Your First AI Project)

IMPORTANT RULES:
- ONLY answer based on the BOOK EXCERPTS provided below. Do NOT make up chapter names, content, or details.
- If the excerpts don't contain enough information to answer, say so honestly and suggest which book/chapter might help.
- Quote or paraphrase from the excerpts when possible.
- Keep answers concise but informative.
- Speak in a warm, helpful tone with occasional pirate/parrot flair.
- Always cite which book and chapter your answer comes from.`;

    let model = null;
    let tokenizerInstance = null;
    let isGenerating = false;

    // ── RAG: Book chunks & search ──
    let bookChunks = [];
    let chunkTokens = []; // pre-tokenized chunks for BM25
    let idf = {};         // inverse document frequency

    // Tokenize text into searchable terms
    function tokenize(text) {
      return text.toLowerCase()
        .replace(/[^\w\s]/g, ' ')
        .split(/\s+/)
        .filter(t => t.length > 2);
    }

    // Build IDF index from all chunks
    function buildIndex(chunks) {
      const N = chunks.length;
      const df = {}; // document frequency

      chunkTokens = chunks.map(c => {
        const tokens = tokenize(c.text + ' ' + c.chapter + ' ' + c.book);
        const unique = new Set(tokens);
        unique.forEach(t => { df[t] = (df[t] || 0) + 1; });
        return tokens;
      });

      // Compute IDF: log(N / df)
      for (const term in df) {
        idf[term] = Math.log((N - df[term] + 0.5) / (df[term] + 0.5) + 1);
      }
    }

    // BM25 search: find top-k relevant chunks for a query
    function searchChunks(query, topK = TOP_K) {
      const queryTokens = tokenize(query);
      const k1 = 1.5, b = 0.75;
      const avgDl = chunkTokens.reduce((s, t) => s + t.length, 0) / chunkTokens.length;

      const scores = chunkTokens.map((docTokens, i) => {
        const dl = docTokens.length;
        let score = 0;

        for (const qt of queryTokens) {
          const tf = docTokens.filter(t => t === qt).length;
          if (tf === 0) continue;
          const termIdf = idf[qt] || 0;
          score += termIdf * ((tf * (k1 + 1)) / (tf + k1 * (1 - b + b * dl / avgDl)));
        }

        return { index: i, score };
      });

      return scores
        .sort((a, b) => b.score - a.score)
        .slice(0, topK)
        .filter(s => s.score > 0)
        .map(s => bookChunks[s.index]);
    }

    // Load and index book chunks
    async function loadBookChunks() {
      try {
        const res = await fetch(CHUNKS_URL);
        const data = await res.json();
        bookChunks = data.chunks;
        buildIndex(bookChunks);
        console.log(`📚 RAG: indexed ${bookChunks.length} book chunks`);
      } catch (err) {
        console.warn('Failed to load book chunks:', err);
      }
    }

    // Build system prompt with relevant context
    function buildSystemPrompt(userQuery) {
      const relevant = searchChunks(userQuery);

      if (relevant.length === 0) {
        return SYSTEM_PROMPT_BASE + '\n\nNo specific book excerpts found for this query. Answer based on the general book descriptions above, or say you\'re not sure.';
      }

      let context = '\n\nBOOK EXCERPTS (retrieved for this question):\n';
      for (const chunk of relevant) {
        context += `\n--- From "${chunk.book}" > ${chunk.chapter} ---\n${chunk.text}\n`;
      }

      return SYSTEM_PROMPT_BASE + context;
    }

    // DOM elements
    const toggle = document.getElementById('chat-toggle');
    const panel = document.getElementById('chat-panel');
    const closeBtn = document.getElementById('chat-close');
    const loadBtn = document.getElementById('chat-load-btn');
    const loaderEl = document.getElementById('chat-loader');
    const loaderInit = document.getElementById('loader-init');
    const loaderProgress = document.getElementById('loader-progress');
    const progressFill = document.getElementById('progress-fill');
    const progressText = document.getElementById('progress-text');
    const progressDetails = document.getElementById('progress-details');
    const messagesEl = document.getElementById('chat-messages');
    const inputArea = document.getElementById('chat-input-area');
    const input = document.getElementById('chat-input');
    const sendBtn = document.getElementById('chat-send');
    const statusEl = document.getElementById('chat-status');

    // Toggle panel
    toggle.addEventListener('click', () => {
      panel.classList.toggle('chat-hidden');
      if (!panel.classList.contains('chat-hidden')) {
        toggle.style.animation = 'none';
      }
    });

    closeBtn.addEventListener('click', () => {
      panel.classList.add('chat-hidden');
    });

    // Load model
    loadBtn.addEventListener('click', async () => {
      loadBtn.disabled = true;
      loadBtn.innerHTML = '<span class="loader-btn-icon">⏳</span> Loading...';
      loaderInit.style.display = 'none';
      loaderProgress.style.display = 'block';

      try {
        progressText.textContent = 'Loading AI engine...';
        const transformers = await import(/* @vite-ignore */ TRANSFORMERS_URL);
        const { AutoTokenizer, AutoModelForCausalLM, TextStreamer } = transformers;
        TextStreamerClass = TextStreamer;

        progressText.textContent = 'Loading tokenizer...';
        tokenizerInstance = await AutoTokenizer.from_pretrained(MODEL_ID);

        progressText.textContent = 'Downloading AI model (q4 WebGPU)...';
        progressDetails.textContent = 'First load downloads ~500MB — cached after';

        model = await AutoModelForCausalLM.from_pretrained(MODEL_ID, {
          dtype: 'q4',
          device: 'webgpu',
          progress_callback: (progress) => {
            if (progress.status === 'progress') {
              const pct = Math.round(progress.progress || 0);
              progressFill.style.width = pct + '%';
              progressText.textContent = `Downloading ${progress.file || 'model'}... ${pct}%`;
              if (progress.loaded && progress.total) {
                const loadedMB = (progress.loaded / 1024 / 1024).toFixed(0);
                const totalMB = (progress.total / 1024 / 1024).toFixed(0);
                progressDetails.textContent = `${loadedMB} MB / ${totalMB} MB`;
              }
            }
          },
        });

        progressFill.style.width = '100%';
        progressText.textContent = '✅ Polly is ready!';
        progressDetails.textContent = 'Model loaded successfully';
        statusEl.innerHTML = '●&nbsp;Online (on-device)';
        statusEl.style.color = '#4ade80';

        // Transition to chat
        setTimeout(() => {
          loaderEl.style.display = 'none';
          messagesEl.style.display = 'flex';
          inputArea.style.display = 'flex';
          sendBtn.disabled = false;
          input.focus();
        }, 800);

      } catch (err) {
        console.error('Model loading failed:', err);
        progressText.textContent = '❌ Failed to load model';
        progressDetails.textContent = err.message || 'Check console for details';
        progressFill.style.background = 'var(--color-pirate-red, #d94f4f)';
        loaderInit.style.display = 'block';
        loadBtn.disabled = false;
        loadBtn.innerHTML = '<span class="loader-btn-icon">🔄</span> Retry';
      }
    });

    // Chat history
    let chatHistory = [];

    // Block image/file pastes — text only
    input.addEventListener('paste', (e) => {
      const clipboardData = e.clipboardData;
      if (!clipboardData) return;

      // Check if paste contains files (images, etc.)
      if (clipboardData.files && clipboardData.files.length > 0) {
        e.preventDefault();
        return;
      }

      // Check if any items are non-text (e.g. image data)
      const hasNonText = Array.from(clipboardData.items || []).some(
        item => !item.type.startsWith('text/')
      );
      if (hasNonText) {
        e.preventDefault();
        // Extract just the plain text if available
        const text = clipboardData.getData('text/plain');
        if (text) {
          document.execCommand('insertText', false, text);
        }
        return;
      }
    });

    // Block drag-and-drop of images/files
    input.addEventListener('drop', (e) => {
      if (e.dataTransfer && e.dataTransfer.files.length > 0) {
        e.preventDefault();
      }
    });

    // Auto-resize textarea
    input.addEventListener('input', () => {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 100) + 'px';
      sendBtn.disabled = !input.value.trim();
    });

    // Send on Enter (Shift+Enter for newline)
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        if (input.value.trim() && !isGenerating) sendMessage();
      }
    });

    sendBtn.addEventListener('click', () => {
      if (input.value.trim() && !isGenerating) sendMessage();
    });

    function addMessage(role, content) {
      const div = document.createElement('div');
      div.className = `chat-msg ${role}`;

      if (role === 'assistant') {
        div.innerHTML = `
          <img src="/parrot-avatar.png" alt="Polly" class="chat-msg-avatar" />
          <div class="chat-msg-bubble">${content}</div>
        `;
      } else {
        // User messages: always escape HTML and strip any images
        const safeContent = escapeHtml(stripNonText(content));
        div.innerHTML = `
          <div class="chat-msg-bubble">${safeContent}</div>
        `;
      }

      messagesEl.appendChild(div);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return div;
    }

    // Strip any image data, data URIs, HTML tags from user input
    function stripNonText(text) {
      return text
        .replace(/<img[^>]*>/gi, '')
        .replace(/data:image\/[^;]+;base64,[A-Za-z0-9+/=]+/g, '')
        .replace(/<[^>]+>/g, '')
        .trim();
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    async function sendMessage() {
      const text = input.value.trim();
      if (!text || !model || isGenerating) return;

      isGenerating = true;
      input.value = '';
      input.style.height = 'auto';
      sendBtn.disabled = true;
      statusEl.innerHTML = '●&nbsp;Thinking...';
      statusEl.style.color = '#fbbf24';

      // Add user message
      addMessage('user', text);
      chatHistory.push({ role: 'user', content: text });

      // Add typing indicator
      const typingDiv = addMessage('assistant', '<div class="typing-dots"><span></span><span></span><span></span></div>');
      const bubbleEl = typingDiv.querySelector('.chat-msg-bubble');

      try {
        // Simple system prompt (no RAG for now — keeps prompt short for fast inference)
        const systemPrompt = `You are Polly, a pirate parrot AI assistant for "The Agentic Crew" books by Rasmus Schlünsen. Rules: answer in 1-2 SHORT sentences max. Be direct and brief. Add pirate/parrot flair sparingly. Never ramble.`;

        // Build prompt string manually (Qwen2 chat template)
        let prompt = `<|im_start|>system\n${systemPrompt}<|im_end|>\n`;
        for (const msg of chatHistory) {
          prompt += `<|im_start|>${msg.role}\n${msg.content}<|im_end|>\n`;
        }
        prompt += '<|im_start|>assistant\n';

        // Tokenize the prompt
        const inputs = tokenizerInstance(prompt, { return_tensors: 'pt' });
        const promptLength = inputs.input_ids.dims[1];

        // Generate with Transformers.js — streaming via TextStreamer
        let responseText = '';
        let tokenCount = 0;
        const startTime = performance.now();

        const streamer = new TextStreamerClass(tokenizerInstance, {
          skip_prompt: true,
          skip_special_tokens: true,
          callback_function: (token) => {
            // Stop if we hit end-of-turn markers
            if (token.includes('<|im_end|>') || token.includes('<|im_start|>')) return;
            responseText += token;
            tokenCount++;
            bubbleEl.innerHTML = formatResponse(responseText);
            messagesEl.scrollTop = messagesEl.scrollHeight;
          },
        });

        await model.generate({
          ...inputs,
          max_new_tokens: 128,
          do_sample: true,
          temperature: 0.7,
          top_p: 0.9,
          streamer,
        });

        responseText = responseText.trim();
        bubbleEl.innerHTML = formatResponse(responseText || '(no response)');

        const elapsed = (performance.now() - startTime) / 1000;
        const tps = (tokenCount / elapsed).toFixed(1);

        const statsDiv = document.createElement('div');
        statsDiv.className = 'chat-stats';
        statsDiv.textContent = `${tokenCount} tokens · ${tps} tok/s · ${MODEL_LABEL}`;
        bubbleEl.appendChild(statsDiv);

        chatHistory.push({ role: 'assistant', content: responseText });

      } catch (err) {
        console.error('Generation failed:', err);
        bubbleEl.innerHTML = '⚠️ Oops, something went wrong. Please try again!';
      }

      isGenerating = false;
      sendBtn.disabled = false;
      statusEl.innerHTML = '●&nbsp;Online (on-device)';
      statusEl.style.color = '#4ade80';
      input.focus();
    }

    function formatResponse(text) {
      // Strip any image/HTML tags the model might generate
      const cleaned = text
        .replace(/<img[^>]*>/gi, '')
        .replace(/<[^>]+>/g, (match) => {
          // Allow only safe inline tags
          if (/^<\/?(strong|em|b|i|br\s*\/?)>$/i.test(match)) return match;
          return '';
        });
      // Basic markdown-like formatting
      return cleaned
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/`(.*?)`/g, '<code style="background:rgba(0,0,0,0.06);padding:1px 5px;border-radius:4px;font-size:12px;">$1</code>')
        .replace(/\n/g, '<br/>');
    }
  })();
</script>
