---
const chapters = [
  { id: "01-introduction", number: "01", title: "Introduction" },
  { id: "02-context", number: "02", title: "Context" },
  { id: "03-what-is-an-agent", number: "03", title: "What Is an Agent?" },
  { id: "04-guardrails", number: "04", title: "Guardrails" },
  { id: "05-git", number: "05", title: "Git as Agent Infrastructure" },
  { id: "06-sandboxes", number: "06", title: "Sandboxes" },
  { id: "07-testing-as-the-feedback-loop", number: "07", title: "Testing as the Feedback Loop" },
  { id: "08-convention-over-configuration", number: "08", title: "Convention Over Configuration" },
  { id: "09-tool-integrations", number: "09", title: "Tool Integrations" },
  { id: "10-local-vs-commercial-llms", number: "10", title: "Local LLMs vs. Commercial LLMs" },
  { id: "11-prompting-as-engineering", number: "11", title: "Prompting as Engineering" },
  { id: "12-multi-agent-orchestration", number: "12", title: "Multi-Agent Orchestration" },
  { id: "13-cicd-and-agents", number: "13", title: "CI/CD and Agents" },
  { id: "14-war-stories", number: "14", title: "War Stories" },
  { id: "15-agents-as-pentesters", number: "15", title: "Agents as Pentesters" },
  { id: "16-when-not-to-use-agents", number: "16", title: "When Not to Use Agents" },
  { id: "17-agentic-teams", number: "17", title: "Agentic Teams" },
  { id: "18-final-words", number: "18", title: "Final Words" },
];
---

<section class="audiobook" id="audiobook">
  <div class="audiobook-inner">
    <div class="audiobook-header">
      <p class="audiobook-eyebrow">
        <span class="eyebrow-icon">&#9835;</span>
        Listen Free
      </p>
      <h2>Audiobook</h2>
      <p class="audiobook-subtitle">Listen to the full book, chapter by chapter. AI-narrated with a bespoke voice designed by Qwen3-TTS.</p>
    </div>

    <div class="audiobook-card">
      <!-- Audio Player -->
      <div class="player-container">
        <div class="now-playing">
          <span class="now-playing-label">Now playing</span>
          <span class="now-playing-title" id="now-playing-title">Select a chapter</span>
        </div>
        <audio id="audiobook-player" controls preload="none">
          Your browser does not support the audio element.
        </audio>
        <div class="bgm-controls">
          <button class="bgm-toggle active" id="bgm-toggle" title="Toggle background music">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M9 18V5l12-2v13"/>
              <circle cx="6" cy="18" r="3"/>
              <circle cx="18" cy="16" r="3"/>
            </svg>
            <span>Music</span>
          </button>
          <input type="range" class="bgm-volume" id="bgm-volume" min="0" max="100" value="30" title="Background music volume" />
        </div>
      </div>

      <!-- Chapter List -->
      <div class="chapter-list-audio">
        {chapters.map((chapter) => (
          <button
            class="chapter-row"
            data-chapter-id={chapter.id}
            data-chapter-title={chapter.title}
            data-chapter-num={chapter.number}
          >
            <span class="chapter-row-num">{chapter.number}</span>
            <span class="chapter-row-title">{chapter.title}</span>
            <span class="chapter-row-play">
              <svg class="play-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                <polygon points="5,3 19,12 5,21" />
              </svg>
              <svg class="pause-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" style="display:none;">
                <rect x="6" y="4" width="4" height="16" />
                <rect x="14" y="4" width="4" height="16" />
              </svg>
            </span>
          </button>
        ))}
      </div>

      <!-- Download Full Book -->
      <div class="download-full">
        <div class="download-full-divider"></div>
        <p class="download-full-label">Download the full audiobook</p>
        <div class="download-full-buttons">
          <a href="/audiobook/adult/kitt/full-book.mp3" class="download-btn" download>
            <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 3v10m0 0l-4-4m4 4l4-4M3 17h14" />
            </svg>
            Full Audiobook (MP3)
          </a>
        </div>
        <p class="download-full-note">Full audiobook files will be available soon. Individual chapters are being added as they are generated.</p>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const player = document.getElementById('audiobook-player') as HTMLAudioElement;
    const nowPlayingTitle = document.getElementById('now-playing-title');
    const chapterRows = document.querySelectorAll('.chapter-row');

    let currentChapterId: string | null = null;

    function getAudioPath(chapterId: string) {
      return `/audiobook/adult/kitt/${chapterId}.mp3`;
    }

    // Chapter selection
    chapterRows.forEach(row => {
      row.addEventListener('click', () => {
        const chapterId = row.getAttribute('data-chapter-id');
        const chapterTitle = row.getAttribute('data-chapter-title');
        const chapterNum = row.getAttribute('data-chapter-num');

        if (!chapterId) return;

        if (currentChapterId === chapterId && player.src) {
          if (player.paused) {
            player.play().catch(() => {});
          } else {
            player.pause();
          }
          return;
        }

        currentChapterId = chapterId;

        if (nowPlayingTitle) {
          nowPlayingTitle.textContent = `${chapterNum}. ${chapterTitle}`;
        }

        chapterRows.forEach(r => r.classList.remove('active'));
        row.classList.add('active');

        player.src = getAudioPath(chapterId);
        player.play().catch(() => {});
      });
    });

    // Update play/pause icons based on audio state
    const updateIcons = () => {
      chapterRows.forEach(row => {
        const playIcon = row.querySelector('.play-icon') as HTMLElement;
        const pauseIcon = row.querySelector('.pause-icon') as HTMLElement;
        const isActive = row.getAttribute('data-chapter-id') === currentChapterId;

        if (isActive && !player.paused) {
          playIcon.style.display = 'none';
          pauseIcon.style.display = 'block';
        } else {
          playIcon.style.display = 'block';
          pauseIcon.style.display = 'none';
        }
      });
    };

    player.addEventListener('play', updateIcons);
    player.addEventListener('pause', updateIcons);
    player.addEventListener('ended', () => {
      updateIcons();
      // Auto-play next chapter
      if (currentChapterId) {
        const rows = Array.from(chapterRows);
        const currentIndex = rows.findIndex(r => r.getAttribute('data-chapter-id') === currentChapterId);
        if (currentIndex >= 0 && currentIndex < rows.length - 1) {
          const nextRow = rows[currentIndex + 1] as HTMLElement;
          nextRow.click();
        }
      }
    });

    // Handle audio errors gracefully (file might not exist yet)
    player.addEventListener('error', () => {
      if (nowPlayingTitle && currentChapterId) {
        nowPlayingTitle.textContent += ' (not yet available)';
      }
    });

    // ========================================
    // BACKGROUND MUSIC
    // ========================================

    const bgMusic = new Audio('/presentation-audio/bg-music.mp3');
    bgMusic.loop = true;
    bgMusic.volume = 0;
    bgMusic.preload = 'auto';

    const BG_HIGH = 0.30;   // Volume when no narration
    const BG_LOW = 0.10;    // Ducked volume during narration
    const BG_FADE_MS = 800;
    const BG_FADE_STEPS = 40;

    let bgEnabled = true;
    let bgStarted = false;
    let bgFadeTimer: number | null = null;

    const bgToggle = document.getElementById('bgm-toggle')!;
    const bgVolumeSlider = document.getElementById('bgm-volume') as HTMLInputElement;

    function fadeBgTo(targetVol: number, duration: number = BG_FADE_MS): Promise<void> {
      return new Promise((resolve) => {
        if (bgFadeTimer) clearInterval(bgFadeTimer);
        const startVol = bgMusic.volume;
        if (Math.abs(startVol - targetVol) < 0.005) {
          bgMusic.volume = targetVol;
          resolve();
          return;
        }
        const steps = BG_FADE_STEPS;
        const stepSize = (targetVol - startVol) / steps;
        const interval = duration / steps;
        let currentStep = 0;
        bgFadeTimer = window.setInterval(() => {
          currentStep++;
          bgMusic.volume = Math.max(0, Math.min(1, startVol + stepSize * currentStep));
          if (currentStep >= steps) {
            clearInterval(bgFadeTimer!);
            bgFadeTimer = null;
            bgMusic.volume = targetVol;
            resolve();
          }
        }, interval);
      });
    }

    function getBgHighVol(): number {
      return (parseInt(bgVolumeSlider.value) / 100) * BG_HIGH * 3;
    }

    function getBgLowVol(): number {
      return (parseInt(bgVolumeSlider.value) / 100) * BG_LOW * 3;
    }

    function startBgMusic() {
      if (bgStarted || !bgEnabled) return;
      bgStarted = true;
      bgMusic.volume = 0;
      bgMusic.play().then(() => {
        fadeBgTo(getBgHighVol(), 2000);
      }).catch(() => {
        bgStarted = false;
      });
    }

    function duckBg() {
      if (!bgStarted || !bgEnabled) return;
      fadeBgTo(getBgLowVol());
    }

    function unduckBg() {
      if (!bgStarted || !bgEnabled) return;
      fadeBgTo(getBgHighVol());
    }

    // Start music on first chapter play
    player.addEventListener('play', () => {
      startBgMusic();
      duckBg();
    });

    player.addEventListener('pause', () => {
      unduckBg();
    });

    player.addEventListener('ended', () => {
      // Check if this is the last chapter
      if (currentChapterId) {
        const rows = Array.from(chapterRows);
        const currentIndex = rows.findIndex(r => r.getAttribute('data-chapter-id') === currentChapterId);
        if (currentIndex >= rows.length - 1) {
          // Last chapter ended — wait 3s then fade out
          setTimeout(() => {
            fadeBgTo(0, 3000).then(() => {
              bgMusic.pause();
              bgStarted = false;
            });
          }, 3000);
        } else {
          // Between chapters, unduck briefly
          unduckBg();
        }
      }
    });

    // Toggle button
    bgToggle.addEventListener('click', () => {
      bgEnabled = !bgEnabled;
      bgToggle.classList.toggle('active', bgEnabled);
      if (!bgEnabled && bgStarted) {
        fadeBgTo(0, 500).then(() => {
          bgMusic.pause();
          bgStarted = false;
        });
      } else if (bgEnabled && !player.paused) {
        startBgMusic();
        duckBg();
      }
    });

    // Volume slider
    bgVolumeSlider.addEventListener('input', () => {
      if (!bgStarted || !bgEnabled) return;
      const isPlaying = !player.paused;
      bgMusic.volume = isPlaying ? getBgLowVol() : getBgHighVol();
    });
  });
</script>

<style>
  .audiobook {
    padding: 6rem 2rem;
    position: relative;
  }

  .audiobook::before {
    content: '';
    position: absolute;
    top: 30%;
    left: 50%;
    width: 50%;
    height: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(46, 155, 183, 0.06), transparent 70%);
    pointer-events: none;
  }

  .audiobook-inner {
    max-width: 650px;
    margin: 0 auto;
    position: relative;
  }

  .audiobook-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .audiobook-eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-pirate-teal);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .eyebrow-icon {
    font-size: 1rem;
  }

  .audiobook-header h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 600;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .audiobook-subtitle {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .audiobook-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.04);
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .audiobook-card:hover {
    border-color: var(--color-pirate-teal);
    box-shadow: 0 8px 40px rgba(46, 155, 183, 0.1);
  }

  /* Player */
  .player-container {
    margin-bottom: 2rem;
    background: var(--color-bg-elevated);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border-light);
  }

  .now-playing {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .now-playing-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-pirate-teal);
    white-space: nowrap;
  }

  .now-playing-title {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
  }

  audio {
    width: 100%;
    height: 40px;
    border-radius: 8px;
  }

  audio::-webkit-media-controls-panel {
    background: var(--color-bg-elevated);
  }

  /* Background Music Controls */
  .bgm-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border-light);
  }

  .bgm-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    font-family: inherit;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .bgm-toggle:hover {
    border-color: var(--color-pirate-teal);
    color: var(--color-text);
  }

  .bgm-toggle.active {
    background: rgba(46, 155, 183, 0.1);
    border-color: var(--color-pirate-teal);
    color: var(--color-pirate-teal);
    font-weight: 600;
  }

  .bgm-toggle.active svg {
    stroke: var(--color-pirate-teal);
  }

  .bgm-volume {
    flex: 1;
    height: 4px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--color-border);
    border-radius: 2px;
    outline: none;
    max-width: 120px;
  }

  .bgm-volume::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-pirate-teal);
    cursor: pointer;
    border: 2px solid white;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
  }

  .bgm-volume::-moz-range-thumb {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-pirate-teal);
    cursor: pointer;
    border: 2px solid white;
    box-shadow: 0 1px 4px rgba(0,0,0,0.15);
  }

  /* Chapter List */
  .chapter-list-audio {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-height: 400px;
    overflow-y: auto;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-border-light);
    border-radius: 12px;
  }

  .chapter-list-audio::-webkit-scrollbar {
    width: 6px;
  }

  .chapter-list-audio::-webkit-scrollbar-track {
    background: transparent;
  }

  .chapter-list-audio::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 3px;
  }

  .chapter-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    border: none;
    border-bottom: 1px solid var(--color-border-light);
    background: transparent;
    cursor: pointer;
    transition: background 0.2s;
    font-family: inherit;
    text-align: left;
    width: 100%;
    color: inherit;
  }

  .chapter-row:last-child {
    border-bottom: none;
  }

  .chapter-row:hover {
    background: rgba(46, 155, 183, 0.04);
  }

  .chapter-row.active {
    background: rgba(46, 155, 183, 0.08);
  }

  .chapter-row-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    min-width: 1.75rem;
    opacity: 0.5;
  }

  .chapter-row.active .chapter-row-num {
    opacity: 1;
    color: var(--color-pirate-teal);
  }

  .chapter-row-title {
    flex: 1;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .chapter-row.active .chapter-row-title {
    color: var(--color-pirate-teal);
    font-weight: 600;
  }

  .chapter-row-play {
    color: var(--color-text-muted);
    opacity: 0.4;
    transition: opacity 0.2s, color 0.2s;
    flex-shrink: 0;
  }

  .chapter-row:hover .chapter-row-play {
    opacity: 0.8;
    color: var(--color-pirate-teal);
  }

  .chapter-row.active .chapter-row-play {
    opacity: 1;
    color: var(--color-pirate-teal);
  }

  /* Download Full */
  .download-full {
    text-align: center;
  }

  .download-full-divider {
    width: 60px;
    height: 1px;
    background: var(--color-border);
    margin: 0 auto 1.25rem;
  }

  .download-full-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .download-full-buttons {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s;
    text-decoration: none;
  }

  .download-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-deep);
    background: rgba(232, 150, 62, 0.06);
    transform: translateY(-1px);
  }

  .download-full-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .audiobook {
      padding: 4rem 1.5rem;
    }

    .audiobook-card {
      padding: 1.75rem 1.25rem;
    }

    .chapter-list-audio {
      max-height: 300px;
    }

    .download-full-buttons {
      flex-direction: column;
      align-items: center;
    }

    .download-btn {
      width: 100%;
      max-width: 220px;
      justify-content: center;
    }
  }
</style>
