<section class="chapters" id="chapters">
  <div class="chapters-inner">
    <div class="chapters-header">
      <h2>What's inside</h2>
      <div class="book-tabs">
        <button class="book-tab active" data-book="engineering">
          <span class="tab-icon">&#9781;</span>
          The Agentic Crew
        </button>
        <button class="book-tab" data-book="crew">
          <span class="tab-icon">&#9783;</span>
          Crew Member's Guide
        </button>
      </div>
    </div>

    <div class="book-panel active" data-book="engineering">
      <p class="chapters-subtitle">18 chapters covering the shift, the tools, and the engineering practices that make agentic work actually work.</p>
      <div class="chapters-illustration">
        <img src="/generated/chapters-illustration.png" alt="Nautical treasure map with circuit traces" loading="lazy" />
        <div class="chapters-illustration-overlay"></div>
      </div>
      <div class="chapter-list">
        {engineeringChapters.map((chapter) => (
          <div class="chapter-item">
            <span class="chapter-num">{chapter.number}</span>
            <div class="chapter-info">
              <h3>{chapter.title}</h3>
              <p>{chapter.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="book-panel" data-book="crew">
      <p class="chapters-subtitle">18 chapters for tech-savvy people who don't write code — understand agents, direct them, and build real things.</p>
      <div class="chapters-illustration crew-illustration">
        <img src="/book-cover-crew.png" alt="Crew Member's Guide cover" loading="lazy" />
        <div class="chapters-illustration-overlay"></div>
      </div>
      <div class="chapter-list">
        {crewChapters.map((chapter) => (
          <div class="chapter-item crew-item">
            <span class="chapter-num crew-num">{chapter.number}</span>
            <div class="chapter-info">
              <h3>{chapter.title}</h3>
              <p>{chapter.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.book-tab');
    const panels = document.querySelectorAll('.book-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const book = tab.getAttribute('data-book');
        tabs.forEach(t => t.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.querySelector(`.book-panel[data-book="${book}"]`)?.classList.add('active');
      });
    });
  });
</script>

<style>
