---
const chapters = [
  {
    number: "01",
    title: "Introduction",
    description: "The fundamental loop of software engineering is breaking. What it means to go from writing software to engineering it — with a crew of agents at your side."
  },
  {
    number: "02",
    title: "Context",
    description: "The single most important skill in agentic engineering isn't prompting — it's context management. Learn to curate what your agents see."
  },
  {
    number: "03",
    title: "What Is an Agent?",
    description: "Placing AI tools on a spectrum from autocomplete to autonomous systems. What makes something truly agentic, how agents fail, and the right mental model for working with them."
  },
  {
    number: "04",
    title: "Principles from Building My Own Agentic Tooling",
    description: "Parallel visibility, structured handovers, configurable trust, and version control as infrastructure — principles that emerged from building a multi-agent control plane."
  },
  {
    number: "05",
    title: "Guardrails",
    description: "The trust gradient, permission scoping, approval gates, and environment-specific rules. How to give agents power without giving them the keys to production."
  },
  {
    number: "06",
    title: "Git as Agent Infrastructure",
    description: "Small commits, descriptive messages, branch-per-task, and worktrees for parallel agents. Git as your undo button and review interface."
  },
  {
    number: "07",
    title: "Sandboxes",
    description: "Giving agents the freedom to be wrong. Worktrees, containers, and ephemeral environments that make failure cheap and experimentation free."
  },
  {
    number: "08",
    title: "Testing as the Feedback Loop",
    description: "Tests become the agent's eyes. TDD as a superpower, fast test suites as agent infrastructure, and the virtuous cycle of better tests and more autonomous agents."
  },
  {
    number: "09",
    title: "Convention Over Configuration",
    description: "Why consistent file naming, formatters, project layouts, and CLAUDE.md files make agents dramatically more effective."
  },
  {
    number: "10",
    title: "Extending the Agent's Reach",
    description: "MCP, tool integrations, and connecting agents to databases, monitoring, and project management. How to give agents eyes beyond the filesystem — and the guardrails to do it safely."
  },
  {
    number: "11",
    title: "Local LLMs vs. Commercial LLMs",
    description: "Privacy, cost, capability trade-offs, team cost management, and getting started without paying the farm. The practical hybrid approach of matching the model to the task."
  },
  {
    number: "12",
    title: "Prompting as Engineering",
    description: "How to write effective agent prompts — task decomposition, constraint specification, the prompt-as-spec pattern, and anti-patterns to avoid."
  },
  {
    number: "13",
    title: "Multi-Agent Orchestration",
    description: "Running agents in parallel, the handover pattern for sequential work, branch-per-agent isolation, and knowing when more agents isn't better."
  },
  {
    number: "14",
    title: "Agents in the Pipeline",
    description: "Using agents in CI/CD — PR pre-screening, overnight agents, cost control in automation, and the trust question when nobody's watching."
  },
  {
    number: "15",
    title: "When Agents Get It Wrong",
    description: "War stories from the field — the eager refactorer, the hallucinated library, the infinite loop — plus a diagnostic playbook for systematically debugging agent failures."
  },
  {
    number: "16",
    title: "When Not to Use Agents",
    description: "The overhead tax, architecture decisions, security-critical code, working with legacy codebases, and the craft argument. Knowing when to put the agent away."
  },
  {
    number: "17",
    title: "Agentic Teams",
    description: "How agent-assisted development changes code review, the junior engineer question, knowledge distribution, compliance and audit trails, hiring, and team rhythms."
  },
  {
    number: "18",
    title: "Final Words",
    description: "The craft isn't dying — it's shedding its skin. What endures, what changes, and why the captain still matters."
  },
];
