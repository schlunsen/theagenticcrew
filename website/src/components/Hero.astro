<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <p class="eyebrow">New Book — March 2026</p>
      <h1>The Agentic Crew</h1>
      <p class="subtitle">How software engineers learn to build with agents</p>
      <p class="description">
        AI agents don't just autocomplete your code. They read your codebase, reason about it,
        make changes across files, run your tests, and iterate. This book is your practical guide
        to the transition — from writing software to <em>engineering</em> it.
      </p>
      <div class="hero-actions">
        <a href="#download" class="btn-primary">Get the Book — Free</a>
        <a href="#chapters" class="btn-secondary">See what's inside</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="book-wrapper">
        <div id="lottie-glow" class="lottie-glow"></div>
        <div class="book-mock">
          <div class="book-cover">
            <div class="book-spine"></div>
            <div class="book-front">
              <img src="/book-cover.png" alt="The Agentic Crew book cover" class="cover-image" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 6rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -20%;
    width: 60%;
    height: 100%;
    background: radial-gradient(ellipse, var(--color-accent-glow), transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-light);
    margin-bottom: 1rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .description {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 520px;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .description em {
    color: var(--color-text);
    font-style: italic;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--color-accent);
    color: #0a0e1a;
    padding: 0.85rem 2rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 1.05rem;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 30px var(--color-accent-glow);
  }

  .btn-primary:hover {
    background: var(--color-accent-light);
    transform: translateY(-2px);
    box-shadow: 0 0 40px rgba(201, 168, 76, 0.3);
    color: #0a0e1a;
  }

  .btn-secondary {
    color: var(--color-text-muted);
    padding: 0.85rem 2rem;
    border-radius: 10px;
    font-weight: 500;
    font-size: 1.05rem;
    border: 1px solid var(--color-border);
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text);
  }

  /* Book mockup */
  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .book-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lottie-glow {
    position: absolute;
    width: 420px;
    height: 520px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
  }

  .book-mock {
    perspective: 800px;
    position: relative;
    z-index: 1;
  }

  .book-cover {
    width: 260px;
    height: 370px;
    position: relative;
    transform: rotateY(-15deg) rotateX(5deg);
    transform-style: preserve-3d;
    transition: transform 0.4s ease;
  }

  .book-cover:hover {
    transform: rotateY(-5deg) rotateX(2deg);
  }

  .book-front {
    width: 100%;
    height: 100%;
    border-radius: 4px 12px 12px 4px;
    overflow: hidden;
    box-shadow:
      10px 10px 30px rgba(0, 0, 0, 0.5),
      0 0 60px var(--color-accent-glow);
    position: relative;
  }

  .cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .book-spine {
    position: absolute;
    left: -20px;
    top: 0;
    width: 20px;
    height: 100%;
    background: linear-gradient(to right, #0a0e1a, #111827);
    transform: rotateY(90deg);
    transform-origin: right;
    border-radius: 4px 0 0 4px;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 5rem 1.5rem 3rem;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }

    .description {
      margin-left: auto;
      margin-right: auto;
      font-size: 0.95rem;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
    }

    .book-cover {
      width: 200px;
      height: 285px;
    }

    .lottie-glow {
      width: 320px;
      height: 400px;
    }

    .btn-primary,
    .btn-secondary {
      padding: 0.75rem 1.5rem;
      font-size: 0.95rem;
    }
  }

  @media (max-width: 400px) {
    .hero {
      padding: 4.5rem 1rem 2rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .book-cover {
      width: 180px;
      height: 256px;
    }

    .lottie-glow {
      width: 280px;
      height: 350px;
    }
  }
</style>

