<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <p class="eyebrow">
        <span class="eyebrow-flag">&#9760;</span>
        New Book — March 2026
      </p>
      <h1 class="title-gradient">
        <span class="title-bg-wrap">
          <span class="title-fluid" aria-hidden="true"></span>
          <span class="title-fluid title-fluid-2" aria-hidden="true"></span>
        </span>
        The Agentic<br/>Crew
      </h1>
      <p class="subtitle">How software engineers learn to build with agents</p>
      <p class="description">
        AI agents don't just autocomplete your code. They read your codebase, reason about it,
        make changes across files, run your tests, and iterate. This book is your practical guide
        to the transition — from writing software to <em>engineering</em> it.
      </p>
      <div class="hero-actions">
        <a href="#download" class="btn-primary">
          <span>Get the Book — Free</span>
          <svg viewBox="0 0 20 20" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10 3v10m0 0l-4-4m4 4l4-4M3 17h14" />
          </svg>
        </a>
        <a href="#chapters" class="btn-secondary">See what's inside</a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-illustration-wrapper">
        <img src="/generated/hero-illustration.png" alt="" class="hero-illustration" loading="eager" />
        <div class="illustration-overlay"></div>
      </div>
      <div class="book-wrapper">
        <div id="lottie-glow" class="lottie-glow"></div>
        <div class="book-mock">
          <div class="book-cover">
            <div class="book-spine"></div>
            <div class="book-front">
              <img src="/book-cover.png" alt="The Agentic Crew book cover" class="cover-image" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Decorative compass rose -->
  <div class="compass-decoration" aria-hidden="true">
    <svg viewBox="0 0 200 200" width="400" height="400" fill="none" stroke="currentColor" opacity="0.06">
      <circle cx="100" cy="100" r="90" stroke-width="0.5" />
      <circle cx="100" cy="100" r="70" stroke-width="0.3" stroke-dasharray="4 8" />
      <circle cx="100" cy="100" r="50" stroke-width="0.3" />
      <line x1="100" y1="5" x2="100" y2="195" stroke-width="0.5" />
      <line x1="5" y1="100" x2="195" y2="100" stroke-width="0.5" />
      <line x1="30" y1="30" x2="170" y2="170" stroke-width="0.3" />
      <line x1="170" y1="30" x2="30" y2="170" stroke-width="0.3" />
      <polygon points="100,10 105,40 100,35 95,40" fill="currentColor" opacity="0.5" />
    </svg>
  </div>
  <!-- Decorative wave at bottom -->
  <div class="hero-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="var(--color-bg)" opacity="0.5" />
    </svg>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 6rem 2rem 4rem;
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #fff8ed 0%, var(--color-bg) 100%);
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -20%;
    width: 60%;
    height: 100%;
    background: radial-gradient(ellipse, rgba(245, 166, 35, 0.08), transparent 70%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -30%;
    right: -15%;
    width: 50%;
    height: 80%;
    background: radial-gradient(ellipse, rgba(46, 155, 183, 0.06), transparent 70%);
    pointer-events: none;
  }

  .compass-decoration {
    position: absolute;
    bottom: -100px;
    left: -100px;
    color: var(--color-accent);
    pointer-events: none;
    animation: spin-slow 120s linear infinite;
  }

  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .hero-wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    pointer-events: none;
  }

  .hero-wave svg {
    width: 100%;
    height: 100%;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .eyebrow-flag {
    font-size: 1rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .title-gradient {
    position: relative;
    background: linear-gradient(
      135deg,
      var(--color-accent) 0%,
      var(--color-accent-deep) 35%,
      #c97b1e 50%,
      var(--color-pirate-teal) 75%,
      var(--color-accent) 100%
    );
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 8s ease-in-out infinite;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* Subtle fluid blobs behind title */
  .title-bg-wrap {
    position: absolute;
    inset: -20px -30px;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
    border-radius: 20px;
  }

  .title-fluid {
    position: absolute;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245, 166, 35, 0.1) 0%, transparent 70%);
    filter: blur(30px);
    animation: fluid-drift 12s ease-in-out infinite;
    top: 10%;
    left: 10%;
  }

  .title-fluid-2 {
    width: 100px;
    height: 100px;
    background: radial-gradient(circle, rgba(46, 155, 183, 0.08) 0%, transparent 70%);
    animation: fluid-drift-2 15s ease-in-out infinite;
    top: 40%;
    left: 60%;
  }

  @keyframes fluid-drift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(60px, 20px) scale(1.2); }
    50% { transform: translate(30px, -15px) scale(0.9); }
    75% { transform: translate(-20px, 25px) scale(1.1); }
  }

  @keyframes fluid-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    30% { transform: translate(-40px, -20px) scale(1.15); }
    60% { transform: translate(20px, 30px) scale(0.85); }
    80% { transform: translate(-15px, -10px) scale(1.05); }
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .description {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 520px;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .description em {
    color: var(--color-text);
    font-style: italic;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-deep));
    color: #fff;
    padding: 0.85rem 2rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 1.05rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 16px rgba(232, 150, 62, 0.3);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent));
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(232, 150, 62, 0.4);
    color: #fff;
  }

  .btn-secondary {
    color: var(--color-text-muted);
    padding: 0.85rem 2rem;
    border-radius: 10px;
    font-weight: 500;
    font-size: 1.05rem;
    border: 1px solid var(--color-border);
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  /* Book mockup */
  .hero-visual {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .hero-illustration-wrapper {
    position: absolute;
    top: -60px;
    left: -40px;
    right: -40px;
    bottom: -60px;
    z-index: 0;
    border-radius: 24px;
    overflow: hidden;
  }

  .hero-illustration {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.18;
    filter: blur(1px) saturate(1.2);
  }

  .illustration-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 20%, var(--color-bg) 75%);
  }

  .book-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .lottie-glow {
    position: absolute;
    width: 420px;
    height: 520px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
  }

  .book-mock {
    perspective: 800px;
    position: relative;
    z-index: 1;
  }

  .book-cover {
    width: 280px;
    height: 400px;
    position: relative;
    transform: rotateY(-15deg) rotateX(5deg);
    transform-style: preserve-3d;
    transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.1));
  }

  .book-cover:hover {
    transform: rotateY(-5deg) rotateX(2deg) scale(1.02);
    filter: drop-shadow(0 25px 50px rgba(0, 0, 0, 0.15));
  }

  .book-front {
    width: 100%;
    height: 100%;
    border-radius: 4px 12px 12px 4px;
    overflow: hidden;
    box-shadow:
      10px 10px 30px rgba(0, 0, 0, 0.15),
      0 0 60px rgba(245, 166, 35, 0.12),
      0 0 100px rgba(245, 166, 35, 0.06),
      inset 0 0 0 1px rgba(255, 255, 255, 0.1);
    position: relative;
  }

  .book-front::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.15) 0%,
      transparent 40%,
      transparent 60%,
      rgba(255, 255, 255, 0.05) 100%
    );
    pointer-events: none;
    z-index: 1;
    border-radius: inherit;
  }

  .cover-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .book-spine {
    position: absolute;
    left: -20px;
    top: 0;
    width: 20px;
    height: 100%;
    background: linear-gradient(to right, #c97b1e, #e8963e);
    transform: rotateY(90deg);
    transform-origin: right;
    border-radius: 4px 0 0 4px;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 5rem 1.5rem 3rem;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }

    .eyebrow {
      justify-content: center;
    }

    .description {
      margin-left: auto;
      margin-right: auto;
      font-size: 0.95rem;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
    }

    .book-cover {
      width: 200px;
      height: 285px;
    }

    .lottie-glow {
      width: 320px;
      height: 400px;
    }

    .btn-primary,
    .btn-secondary {
      padding: 0.75rem 1.5rem;
      font-size: 0.95rem;
    }

    .compass-decoration {
      display: none;
    }

    .hero-illustration-wrapper {
      display: none;
    }
  }

  @media (max-width: 400px) {
    .hero {
      padding: 4.5rem 1rem 2rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .book-cover {
      width: 180px;
      height: 256px;
    }

    .lottie-glow {
      width: 280px;
      height: 350px;
    }
  }
</style>

