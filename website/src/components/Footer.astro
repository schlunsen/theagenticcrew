---
---

<footer>
  <div class="footer-inner">
    <div class="footer-compass" aria-hidden="true">
      <span class="footer-flag">&#9760;</span>
    </div>
    <p class="footer-title">The Agentic Crew</p>
    <p class="footer-tagline">Chart your course. Lead your crew.</p>
    <p class="footer-copy">&copy; 2026 Rasmus Bornhoft Schlunsen. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    padding: 3rem 2rem;
    border-top: 1px solid var(--color-border);
    position: relative;
    background: var(--color-bg);
  }

  footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
    opacity: 0.3;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }

  .footer-compass {
    margin-bottom: 1rem;
    opacity: 0.4;
  }

  .footer-flag {
    font-size: 1.5rem;
    color: var(--color-accent);
  }

  .footer-title {
    font-family: var(--font-serif);
    font-weight: 600;
    margin-bottom: 0.25rem;
    font-size: 1rem;
    color: var(--color-text);
  }

  .footer-tagline {
    font-size: 0.8rem;
    color: var(--color-accent);
    font-style: italic;
    margin-bottom: 0.75rem;
    opacity: 0.7;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.5;
  }
</style>
