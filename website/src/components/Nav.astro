---
interface Props {
  btnLabel?: string;
  btnHref?: string;
  btnFrom?: string;
  btnTo?: string;
  btnFromHover?: string;
  btnShadow?: string;
  isSubpage?: boolean;
}

const {
  btnLabel    = "Get the Book",
  btnHref     = "#download",
  btnFrom     = "#e8963e",
  btnTo       = "#c97b1e",
  btnFromHover = "#f5a623",
  btnShadow   = "rgba(232, 150, 62, 0.28)",
  isSubpage   = false,
} = Astro.props;
---

<nav>
  <div class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-flag" aria-hidden="true">&#9760;</span>
      The Agentic Crew
    </a>
    <!-- Desktop nav links -->
    <div class="nav-links">
      <a href={isSubpage ? "/#about" : "#about"}>About</a>
      <a href={isSubpage ? "/#chapters" : "#chapters"}>Chapters</a>
      <div class="nav-dropdown">
        <button class="nav-dropdown-btn" aria-expanded="false" aria-haspopup="true">
          Books <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3.5l3 3 3-3"/></svg>
        </button>
        <div class="nav-dropdown-menu" role="menu">
          <a href="/books/the-agentic-crew" role="menuitem">
            <span class="dm-label">The Agentic Crew</span>
            <span class="dm-sub">Engineering book · 4 languages</span>
          </a>
          <a href="/books/crew-guide" role="menuitem">
            <span class="dm-label">Crew Member's Guide</span>
            <span class="dm-sub">For non-coders · 2 languages</span>
          </a>
          <a href="/books/hands-on" role="menuitem">
            <span class="dm-label">Hands-On Guide</span>
            <span class="dm-sub">Practical exercises</span>
          </a>
        </div>
      </div>
      <a href={btnHref} class="btn-nav">{btnLabel}</a>
    </div>

    <!-- Mobile hamburger button -->
    <button class="mobile-menu-btn" aria-label="Open menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <!-- Mobile menu overlay -->
    <div class="mobile-overlay" aria-hidden="true"></div>

    <!-- Mobile slide-out drawer -->
    <div class="mobile-drawer" aria-hidden="true">
      <div class="mobile-drawer-header">
        <span class="logo" aria-hidden="true">
          <span class="logo-flag">&#9760;</span>
          The Agentic Crew
        </span>
        <button class="mobile-close-btn" aria-label="Close menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M4 4l12 12M16 4L4 16"/>
          </svg>
        </button>
      </div>
      <div class="mobile-drawer-links">
        <a href={isSubpage ? "/#about" : "#about"}>About</a>
        <a href={isSubpage ? "/#chapters" : "#chapters"}>Chapters</a>
        <div class="mobile-books-section">
          <span class="mobile-books-label">Books</span>
          <a href="/books/the-agentic-crew" class="mobile-book-link">
            <span class="dm-label">The Agentic Crew</span>
            <span class="dm-sub">Engineering book · 4 languages</span>
          </a>
          <a href="/books/crew-guide" class="mobile-book-link">
            <span class="dm-label">Crew Member's Guide</span>
            <span class="dm-sub">For non-coders · 2 languages</span>
          </a>
          <a href="/books/hands-on" class="mobile-book-link">
            <span class="dm-label">Hands-On Guide</span>
            <span class="dm-sub">Practical exercises</span>
          </a>
        </div>
      </div>
      <div class="mobile-drawer-cta">
        <a href={btnHref} class="btn-nav">{btnLabel}</a>
      </div>
    </div>
  </div>
</nav>

<style define:vars={{ btnFrom, btnTo, btnFromHover, btnShadow }}>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(255, 253, 247, 0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.15rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .logo-flag {
    font-size: 1.3rem;
    transition: transform 0.6s ease;
  }

  .logo:hover { color: var(--btnFrom); }
  .logo:hover .logo-flag { transform: rotate(15deg) scale(1.15); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .nav-links a:hover { color: var(--color-text); }

  /* ── CTA button — colour driven by props ── */
  .btn-nav {
    background: linear-gradient(135deg, var(--btnFrom), var(--btnTo));
    color: #fff !important;
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    font-weight: 600;
    box-shadow: 0 2px 12px var(--btnShadow);
    transition: transform 0.2s, box-shadow 0.2s, opacity 0.2s;
  }

  .btn-nav:hover {
    background: linear-gradient(135deg, var(--btnFromHover), var(--btnFrom));
    transform: translateY(-1px);
    box-shadow: 0 4px 20px var(--btnShadow);
    color: #fff !important;
  }

  /* ── Books dropdown ── */
  .nav-dropdown { position: relative; }

  .nav-dropdown-btn {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-size: 0.9rem; color: var(--color-text-muted); font-weight: 500;
    background: none; border: none; cursor: pointer; font-family: inherit;
    padding: 0; transition: color 0.2s;
  }

  .nav-dropdown-btn:hover { color: var(--color-text); }
  .nav-dropdown-btn svg { transition: transform 0.2s; }
  .nav-dropdown-btn[aria-expanded="true"] svg { transform: rotate(180deg); }

  .nav-dropdown-menu {
    display: none;
    position: absolute; top: calc(100% + 0.75rem); left: 50%;
    transform: translateX(-50%);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.1);
    min-width: 220px;
    overflow: hidden;
    z-index: 200;
  }

  .nav-dropdown-menu.open { display: block; }

  .nav-dropdown-menu a {
    display: flex; flex-direction: column; gap: 0.15rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--color-border-light);
    transition: background 0.15s;
    color: var(--color-text) !important;
  }

  .nav-dropdown-menu a:last-child { border-bottom: none; }
  .nav-dropdown-menu a:hover { background: var(--color-bg-elevated); color: var(--color-text) !important; }

  .dm-label { font-size: 0.9rem; font-weight: 600; color: var(--color-text); }
  .dm-sub   { font-size: 0.75rem; color: var(--color-text-muted); }

  /* ── Mobile hamburger button ── */
  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    z-index: 110;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile overlay ── */
  .mobile-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 149;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mobile-overlay.open {
    display: block;
    opacity: 1;
  }

  /* ── Mobile drawer ── */
  .mobile-drawer {
    display: none;
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: min(320px, 85vw);
    background: var(--color-bg);
    z-index: 150;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -8px 0 40px rgba(0, 0, 0, 0.12);
    overflow-y: auto;
  }

  .mobile-drawer.open {
    transform: translateX(0);
  }

  .mobile-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-drawer-header .logo {
    font-size: 1rem;
    pointer-events: none;
  }

  .mobile-close-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .mobile-close-btn:hover {
    color: var(--color-text);
  }

  .mobile-drawer-links {
    display: flex;
    flex-direction: column;
    padding: 1rem 0;
    flex: 1;
  }

  .mobile-drawer-links > a {
    display: block;
    padding: 0.9rem 1.5rem;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    transition: background 0.15s;
  }

  .mobile-drawer-links > a:hover {
    background: var(--color-bg-elevated);
  }

  .mobile-books-section {
    display: flex;
    flex-direction: column;
    margin-top: 0.5rem;
    border-top: 1px solid var(--color-border-light);
    padding-top: 0.5rem;
  }

  .mobile-books-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    padding: 0.5rem 1.5rem 0.25rem;
  }

  .mobile-book-link {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.75rem 1.5rem 0.75rem 2rem;
    transition: background 0.15s;
  }

  .mobile-book-link:hover {
    background: var(--color-bg-elevated);
  }

  .mobile-drawer-cta {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .mobile-drawer-cta .btn-nav {
    display: block;
    text-align: center;
    width: 100%;
    padding: 0.75rem 1.25rem;
    font-size: 1rem;
  }

  @media (max-width: 640px) {
    .nav-links { display: none; }
    .mobile-menu-btn { display: flex; }
    .mobile-drawer { display: flex; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    /* ── Desktop dropdown ── */
    const btn  = document.querySelector('.nav-dropdown-btn') as HTMLButtonElement | null;
    const menu = document.querySelector('.nav-dropdown-menu');
    if (btn && menu) {
      btn.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(open));
      });

      document.addEventListener('click', (e) => {
        if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
          menu.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    }

    /* ── Mobile menu ── */
    const hamburger = document.querySelector('.mobile-menu-btn') as HTMLButtonElement | null;
    const drawer    = document.querySelector('.mobile-drawer');
    const overlay   = document.querySelector('.mobile-overlay');
    const closeBtn  = document.querySelector('.mobile-close-btn');

    if (!hamburger || !drawer || !overlay) return;

    function openMobile() {
      drawer!.classList.add('open');
      overlay!.classList.add('open');
      hamburger!.setAttribute('aria-expanded', 'true');
      drawer!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeMobile() {
      drawer!.classList.remove('open');
      overlay!.classList.remove('open');
      hamburger!.setAttribute('aria-expanded', 'false');
      drawer!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    hamburger.addEventListener('click', () => {
      const isOpen = drawer!.classList.contains('open');
      isOpen ? closeMobile() : openMobile();
    });

    overlay.addEventListener('click', closeMobile);
    closeBtn?.addEventListener('click', closeMobile);

    // Close on link click (for smooth scroll anchors)
    drawer!.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMobile);
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer!.classList.contains('open')) {
        closeMobile();
      }
    });
  });
</script>
